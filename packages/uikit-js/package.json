{
  "name": "@freecodecamp/uikit-js",
  "version": "1.0.0",
  "scripts": {
    "test": "echo '[packages/uikit-js] no tests yet' && exit 0",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "author": "freeCodeCamp.org <team@freecodecamp.org>",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/UIkit.git",
    "directory": "packages/uikit-js"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/UIkit/issues"
  },
  "homepage": "https://design.freecodecamp.org",
  "description": "Vanilla JS runtime for freeCodeCamp UIKit — wires data-uikit-* attributes to Zag state machines",
  "keywords": [
    "freecodecamp",
    "uikit",
    "design-system",
    "vanilla-js",
    "cdn",
    "accessibility"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/uikit.js",
  "module": "./dist/uikit.js",
  "types": "./dist/uikit.d.ts",
  "exports": {
    ".": {
      "types": "./dist/uikit.d.ts",
      "import": "./dist/uikit.js"
    },
    "./iife": "./dist/uikit.global.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@zag-js/combobox": "^1.40.0",
    "@zag-js/dialog": "^1.40.0",
    "@zag-js/listbox": "^1.40.0",
    "@zag-js/pagination": "^1.40.0",
    "@zag-js/tabs": "^1.40.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
