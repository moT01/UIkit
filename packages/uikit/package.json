{
  "name": "@freecodecamp/uikit",
  "version": "0.1.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup && node scripts/gen-props.mjs",
    "dev": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "author": "freeCodeCamp.org <team@freecodecamp.org>",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/ui.git",
    "directory": "packages/uikit"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/ui/issues"
  },
  "homepage": "https://fcc-uikit.netlify.app",
  "description": "React components for freeCodeCamp's Command-line Chic design system",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives.js",
      "require": "./dist/primitives.cjs",
      "types": "./dist/primitives.d.ts"
    },
    "./forms": {
      "import": "./dist/forms.js",
      "require": "./dist/forms.cjs",
      "types": "./dist/forms.d.ts"
    },
    "./overlays": {
      "import": "./dist/overlays.js",
      "require": "./dist/overlays.cjs",
      "types": "./dist/overlays.d.ts"
    },
    "./navigation": {
      "import": "./dist/navigation.js",
      "require": "./dist/navigation.cjs",
      "types": "./dist/navigation.d.ts"
    },
    "./data-display": {
      "import": "./dist/data-display.js",
      "require": "./dist/data-display.cjs",
      "types": "./dist/data-display.d.ts"
    },
    "./layouts": {
      "import": "./dist/layouts.js",
      "require": "./dist/layouts.cjs",
      "types": "./dist/layouts.d.ts"
    },
    "./props.json": "./dist/props.json",
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@ark-ui/react": "^5.36.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "@ark-ui/react": "^5.0.0",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  }
}
