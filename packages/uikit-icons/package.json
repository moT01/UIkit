{
  "name": "@freecodecamp/uikit-icons",
  "version": "1.0.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup && node scripts/build-sprite.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "author": "freeCodeCamp.org <team@freecodecamp.org>",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/UIkit.git",
    "directory": "packages/uikit-icons"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/UIkit/issues"
  },
  "homepage": "https://fcc-uikit.netlify.app",
  "description": "Curated Lucide icon subset for the freeCodeCamp UIKit",
  "keywords": [
    "freecodecamp",
    "uikit",
    "icons",
    "svg",
    "react",
    "sprite"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./sprite.svg": "./dist/sprite.svg",
    "./package.json": "./package.json"
  }
}
