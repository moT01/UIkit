{
  "name": "@freecodecamp/uikit-icons",
  "version": "0.1.0",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup && node scripts/build-sprite.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "author": "freeCodeCamp.org <team@freecodecamp.org>",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/ui.git",
    "directory": "packages/uikit-icons"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/ui/issues"
  },
  "homepage": "https://fcc-uikit.netlify.app",
  "description": "Curated Lucide icon subset for the freeCodeCamp UIKit",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react.d.ts"
    },
    "./sprite.svg": "./dist/sprite.svg"
  }
}
