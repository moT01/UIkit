{
  "name": "fcc-uikit-monorepo",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "prepare": "is-ci || husky",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier . --write && eslint . --fix",
    "format:check": "prettier . --check && eslint .",
    "changeset": "changeset",
    "release": "turbo run build && changeset publish",
    "preview": "turbo run preview --filter=@freecodecamp/uikit-docs",
    "dev:docs": "turbo run dev --filter=@freecodecamp/uikit-docs",
    "dev:uikit": "pnpm --filter @freecodecamp/uikit dev",
    "dev:vanilla": "pnpm --filter @freecodecamp/uikit-js dev",
    "test:watch": "pnpm --filter @freecodecamp/uikit test:watch",
    "build:docs": "turbo run build --filter=@freecodecamp/uikit-docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.58.2"
  },
  "lint-staged": {
    "**/*.{astro,mjs,cjs,js,jsx,ts,tsx,yaml,yml}": [
      "pnpm format"
    ],
    "**/*.{mdx,md}": [
      "pnpm exec prettier . --write"
    ]
  },
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
