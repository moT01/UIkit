{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>freeCodeCamp/renovate-config"],
  "packageRules": [
    {
      "description": "Auto-merge dev-tooling minor + patch updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchPackageNames": [
        "@types/**",
        "eslint",
        "eslint-**",
        "@eslint/**",
        "typescript-eslint",
        "prettier",
        "prettier-**",
        "vitest",
        "@vitest/**",
        "@testing-library/**",
        "jsdom",
        "tsup",
        "tsx",
        "turbo",
        "globals",
        "is-ci",
        "husky",
        "lint-staged"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Hold majors of every dep for human review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Hold framework + peer deps even on minor + patch",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom",
        "astro",
        "@astrojs/**",
        "@ark-ui/**",
        "@zag-js/**",
        "lightningcss"
      ],
      "automerge": false
    },
    {
      "description": "Workspace deps managed via changesets, not Renovate",
      "matchPackageNames": ["@freecodecamp/**"],
      "enabled": false
    }
  ]
}
