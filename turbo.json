{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-cdn/**", ".astro/**", "!.astro/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:visual": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "test:visual:update": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "verify": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@freecodecamp/uikit-css#build": {
      "dependsOn": [],
      "outputs": []
    }
  }
}
