# Default: text, normalise to LF on commit
* text=auto eol=lf

# Lockfile is generated — keep diff stats clean
pnpm-lock.yaml linguist-generated=true -diff

# CSS bundles + sprite are built artefacts
**/dist/** linguist-generated=true
**/dist-cdn/** linguist-generated=true

# Fonts are binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Image binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary

# Playwright snapshots are PNGs
**/__snapshots__/**/*.png binary

# Archive formats
*.zip binary
*.tar.gz binary
*.gz binary
