---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Navbar, Button, Link } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='navbar'
  slug='Navbar'
  title='Navbar'
  previewStacked
  previewPlain
  description='Top app bar — three-zone (start / center / end), theme-flat, no shadow.'
  source='navigation/Navbar.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <Navbar style={{ maxWidth: '760px', margin: '0 auto' }}>
      <div class='navbar__start'><strong>freeCodeCamp</strong></div>
      <div class='navbar__center'>
        <a class='fcc-link' href='#curriculum'>Curriculum</a>
        <a class='fcc-link' href='#forum'>Forum</a>
        <a class='fcc-link' href='#news'>News</a>
      </div>
      <div class='navbar__end'>
        <Button variant='cta'>Sign in</Button>
      </div>
    </Navbar>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Navbar, Button, Link } from '@freecodecamp/uikit';

<Navbar
  start={<strong>freeCodeCamp</strong>}
  center={
    <>
      <Link href="/learn">Curriculum</Link>
      <Link href="/forum">Forum</Link>
      <Link href="/news">News</Link>
    </>
  }
  end={<Button variant="cta">Sign in</Button>}
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<nav class="navbar">
  <div class="navbar__start"><strong>freeCodeCamp</strong></div>
  <div class="navbar__center"><a class="fcc-link" href="#">Curriculum</a></div>
  <div class="navbar__end"><button class="btn btn--cta">Sign in</button></div>
</nav>`}
  />
</PlaygroundCard>
