---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { DescriptionList as DescriptionListCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='description-list'
  slug='DescriptionList'
  title='Description list'
  previewStacked
  description='Term + detail metadata pair — stacked or inline layout.'
  source='data-display/DescriptionList.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <DescriptionListCmp
      items={[
        { term: 'Username', detail: 'camper-42' },
        { term: 'Joined', detail: '2014-04-12' },
        { term: 'Certifications', detail: '3 of 14' }
      ]}
      style={{ maxWidth: '480px', margin: '0 auto' }}
    />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { DescriptionList } from '@freecodecamp/uikit';

<DescriptionList
  items={[
    { term: 'Username', detail: 'camper-42' },
    { term: 'Joined', detail: '2014-04-12' },
    { term: 'Certifications', detail: '3 of 14' }
  ]}
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<dl class="dl">
  <dt class="dl__term">Username</dt>
  <dd class="dl__detail">camper-42</dd>
</dl>`}
  />
</PlaygroundCard>
