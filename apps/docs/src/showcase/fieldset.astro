---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import {
  Fieldset as FieldsetCmp,
  RadioGroup,
  Radio
} from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='fieldset'
  slug='Fieldset'
  title='Fieldset'
  previewStacked
  description='Groups related controls under a legend — required for radio groups.'
  source='forms/Fieldset.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FieldsetCmp
      legend='Notification cadence'
      style={{ maxWidth: '480px', margin: '0 auto' }}
    >
      <RadioGroup name='cadence-demo' defaultValue='weekly'>
        <Radio value='weekly' label='Weekly digest' />
        <Radio value='per-cert' label='Per-cert' />
        <Radio value='never' label='Never' />
      </RadioGroup>
    </FieldsetCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Fieldset, RadioGroup, Radio } from '@freecodecamp/uikit';

<Fieldset legend="Notification cadence">
  <RadioGroup name="cadence" defaultValue="weekly">
    <Radio value="weekly" label="Weekly digest" />
    <Radio value="per-cert" label="Per-cert" />
    <Radio value="never" label="Never" />
  </RadioGroup>
</Fieldset>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<fieldset class="fieldset">
  <legend class="fieldset__legend">Notification cadence</legend>
  <label class="radio"><input type="radio" name="cadence" /> Weekly digest</label>
</fieldset>`}
  />
</PlaygroundCard>
