---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Table as TableCmp, Badge } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='table'
  slug='Table'
  title='Table'
  previewStacked
  description='Rule-heavy, square, mono-numeric — for progress and diagnostic data.'
  source='data-display/Table.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <TableCmp style={{ maxWidth: '640px', margin: '0 auto' }}>
      <thead>
        <tr
          ><th>Certification</th><th>Projects</th><th>Hours</th><th>Status</th
          ></tr
        >
      </thead>
      <tbody>
        <tr
          ><td>Responsive Web Design</td><td>5 / 5</td><td>300</td><td
            ><Badge variant='success'>Passed</Badge></td
          ></tr
        >
        <tr
          ><td>JavaScript Algorithms</td><td>4 / 5</td><td>300</td><td
            ><Badge variant='warning'>In review</Badge></td
          ></tr
        >
        <tr
          ><td>Relational Databases</td><td>0 / 5</td><td>300</td><td
            ><Badge>Not started</Badge></td
          ></tr
        >
      </tbody>
    </TableCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Table, Badge } from '@freecodecamp/uikit';

<Table>
  <thead>
    <tr><th>Certification</th><th>Projects</th><th>Status</th></tr>
  </thead>
  <tbody>
    <tr><td>Responsive Web Design</td><td>5 / 5</td><td><Badge variant="success">Passed</Badge></td></tr>
  </tbody>
</Table>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<table class="table">
  <thead><tr><th>Certification</th><th>Projects</th><th>Status</th></tr></thead>
  <tbody>
    <tr><td>Responsive Web Design</td><td>5 / 5</td><td><span class="badge badge--success">Passed</span></td></tr>
  </tbody>
</table>`}
  />
</PlaygroundCard>
