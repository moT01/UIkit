---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Spacer } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='spacer'
  slug='Spacer'
  title='Spacer'
  previewPlain
  description='Explicit whitespace on an 8-step scale.'
  source='primitives/Spacer.tsx'
  status='stable'
  since='1.0.0'
  tokens={['--space-1', '--space-2', '--space-3', '--space-4', '--space-5']}
>
  <Fragment slot='preview'>
    <div
      style='display:flex;align-items:center;gap:0;color:var(--foreground-muted);font-family:var(--font-mono);font-size:13px;'
    >
      <span>start</span>
      <Spacer size={6} />
      <span>end</span>
    </div>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Spacer } from '@freecodecamp/uikit';

<div style={{ display: 'flex' }}>
  <span>start</span>
  <Spacer size={6} />
  <span>end</span>
</div>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<span class="spacer" style="width:48px"></span>`}
  />
</PlaygroundCard>
