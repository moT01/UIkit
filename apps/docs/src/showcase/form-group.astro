---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import {
  FormGroup as FormGroupCmp,
  Input,
  HelpBlock
} from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='form-group'
  slug='FormGroup'
  title='Form group'
  previewStacked
  description='Groups a label, control, and help text with consistent spacing.'
  source='forms/FormGroup.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FormGroupCmp style={{ maxWidth: '420px', margin: '0 auto' }}>
      <label class='form-label' for='username-demo'>Username</label>
      <Input id='username-demo' defaultValue='camper-42' />
      <HelpBlock>Letters, numbers, and dashes. Public.</HelpBlock>
    </FormGroupCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { FormGroup, Input, HelpBlock } from '@freecodecamp/uikit';

<FormGroup>
  <label htmlFor="username">Username</label>
  <Input id="username" defaultValue="camper-42" />
  <HelpBlock>Letters, numbers, and dashes. Public.</HelpBlock>
</FormGroup>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="form-group">
  <label class="form-label" for="username">Username</label>
  <input class="input" id="username" value="camper-42" />
  <p class="form-help">Letters, numbers, and dashes. Public.</p>
</div>`}
  />
</PlaygroundCard>
