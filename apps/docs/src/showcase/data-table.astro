---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { DataTable as DataTableCmp, Badge } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='data-table'
  slug='DataTable'
  title='Data table'
  previewStacked
  description='Sortable, selectable, paginated table — header sort buttons, optional row select.'
  source='data-display/DataTable.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <DataTableCmp
      columns={[
        { id: 'cert', header: 'Cert', accessor: 'cert', sortable: true },
        { id: 'hours', header: 'Hours', accessor: 'hours', align: 'right' },
        { id: 'status', header: 'Status', accessor: 'status', align: 'center' }
      ]}
      rows={[
        {
          id: 'rwd',
          cert: 'Responsive Web Design',
          hours: 300,
          status: 'Passed'
        },
        {
          id: 'js',
          cert: 'JavaScript Algorithms',
          hours: 300,
          status: 'In review'
        }
      ]}
    />
    <Badge variant='success'>Passed</Badge>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { DataTable } from '@freecodecamp/uikit';
import { useState } from 'react';

const [sortBy, setSortBy] = useState({ columnId: 'cert', direction: 'asc' });

<DataTable
  columns={[
    { id: 'cert', header: 'Cert', sortable: true },
    { id: 'hours', header: 'Hours', align: 'right' },
    { id: 'status', header: 'Status', align: 'center' }
  ]}
  rows={rows}
  sortBy={sortBy}
  onSortChange={setSortBy}
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="data-table">
  <table class="data-table__table">
    <thead><tr><th class="data-table__header">Cert</th></tr></thead>
    <tbody><tr><td class="data-table__cell">Responsive Web Design</td></tr></tbody>
  </table>
</div>`}
  />
</PlaygroundCard>
