---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import RadioDemo from './_islands/RadioDemo.tsx';
---

<PlaygroundCard
  id='radio'
  slug='Radio'
  title='Radio'
  previewStacked
  description='Mutually exclusive choice — group with `name` or `radio-group`.'
  source='forms/Radio.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/radio/'
>
  <Fragment slot='preview'>
    <RadioDemo client:idle />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Radio, RadioGroup } from '@freecodecamp/uikit';

<RadioGroup name="theme" defaultValue="dark" label="Theme">
  <Radio value="dark" label="Dark — default" />
  <Radio value="light" label="Light" />
  <Radio value="system" label="System" />
</RadioGroup>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="radio-group" role="radiogroup">
  <label class="radio"><input type="radio" name="theme" checked /> Dark</label>
  <label class="radio"><input type="radio" name="theme" /> Light</label>
</div>`}
  />
</PlaygroundCard>
