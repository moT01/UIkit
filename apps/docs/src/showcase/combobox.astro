---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { ComboboxDemo } from './_islands/ComboboxDemo';
---

<PlaygroundCard
  id='combobox'
  slug='Combobox'
  title='Combobox'
  previewStacked
  description='Typeahead select — Ark UI combobox machine. Filters as you type.'
  source='navigation/Combobox.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/combobox/'
>
  <Fragment slot='preview'>
    <ComboboxDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Combobox, filterItemsByLabel } from '@freecodecamp/uikit';
import { useMemo, useState } from 'react';

const ALL = [
  { value: 'rwd', label: 'Responsive Web Design' },
  { value: 'js',  label: 'JavaScript Algorithms' }
];

const [query, setQuery] = useState('');
const [value, setValue] = useState<string | null>(null);
const items = useMemo(() => filterItemsByLabel(ALL, query), [query]);

<Combobox
  inputValue={query}
  onInputValueChange={setQuery}
  value={value}
  onValueChange={setValue}
  items={items}
  placeholder='Pick a certification'
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="combobox" role="combobox" aria-expanded="true">
  <input class="combobox__input" type="text" />
  <ul class="combobox__list" role="listbox">
    <li class="combobox__item" role="option">Responsive Web Design</li>
  </ul>
</div>`}
  />
</PlaygroundCard>
