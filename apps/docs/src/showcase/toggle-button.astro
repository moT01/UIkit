---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { ToggleButton } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='toggle-button'
  slug='ToggleButton'
  title='Toggle button'
  description='For stateful binary choices — hours pressed, unit selected, dark mode on.'
  source='forms/ToggleButton.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/button/'
>
  <Fragment slot='preview'>
    <ToggleButton defaultPressed={false} client:visible
      >Not pressed</ToggleButton
    >
    <ToggleButton defaultPressed={true} client:visible>Keyboard on</ToggleButton
    >
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { useState } from 'react';
import { ToggleButton } from '@freecodecamp/uikit';

export function Pressed() {
  const [on, setOn] = useState(false);
  return (
    <ToggleButton pressed={on} onPressedChange={setOn}>
      {on ? 'On' : 'Off'}
    </ToggleButton>
  );
}`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<button class="toggle-btn" aria-pressed="false">Off</button>
<button class="toggle-btn" aria-pressed="true">On</button>`}
  />
</PlaygroundCard>
