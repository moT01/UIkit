---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { CommandPaletteDemo } from './_islands/CommandPaletteDemo';
---

<PlaygroundCard
  id='command-palette'
  slug='CommandPalette'
  title='Command palette'
  previewStacked
  previewPlain
  description='⌘K spotlight — global commands, grouped, keyboard-shortcut hinted.'
  source='overlays/CommandPalette.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/dialog-modal/'
>
  <Fragment slot='preview'>
    <CommandPaletteDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { CommandPalette } from '@freecodecamp/uikit';

const GROUPS = [
  { label: 'Navigation', items: [
    { id: 'curriculum', label: 'Go to curriculum', shortcut: 'G C' }
  ]}
];

<CommandPalette
  open={open}
  onClose={() => setOpen(false)}
  onSelect={id => navigate(id)}
  groups={GROUPS}
  placeholder='Type a command or search…'
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="command-palette" role="dialog">
  <input class="command-palette__search" type="text" />
  <ul class="command-palette__list">…</ul>
</div>`}
  />
</PlaygroundCard>
