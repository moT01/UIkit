---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { DropdownDemo } from './_islands/DropdownDemo';
---

<PlaygroundCard
  id='dropdown'
  slug='Dropdown'
  title='Dropdown'
  previewPlain
  description='Menu anchored to a trigger — overflow actions, filters, sort.'
  source='overlays/Dropdown.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/menubar/'
>
  <Fragment slot='preview'>
    <DropdownDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Dropdown } from '@freecodecamp/uikit';

<Dropdown>
  <Dropdown.Toggle>Sort</Dropdown.Toggle>
  <Dropdown.Menu>
    <Dropdown.Item>Most recent</Dropdown.Item>
    <Dropdown.Item active>Alphabetical</Dropdown.Item>
    <Dropdown.Item>Hardest first</Dropdown.Item>
  </Dropdown.Menu>
</Dropdown>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="dropdown">
  <button class="btn" aria-expanded="true">Sort</button>
  <div class="dropdown__menu">
    <a class="dropdown__item" href="#">Most recent</a>
    <a class="dropdown__item dropdown__item--active" href="#">Alphabetical</a>
  </div>
</div>`}
  />
</PlaygroundCard>
