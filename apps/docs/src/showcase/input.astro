---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { FormGroup, Input as InputCmp, HelpBlock } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='input'
  slug='Input'
  title='Input'
  previewStacked
  description='Text input with a built-in label, helper text, and error slot.'
  source='forms/Input.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FormGroup style={{ maxWidth: '360px', margin: '0 auto' }}>
      <label class='form-label' for='email-demo'>Email address</label>
      <InputCmp id='email-demo' type='email' placeholder='camper@example.com' />
      <HelpBlock>We send one curriculum update per week.</HelpBlock>
    </FormGroup>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { FormGroup, Input, HelpBlock } from '@freecodecamp/uikit';

<FormGroup>
  <label htmlFor="email">Email address</label>
  <Input id="email" type="email" placeholder="camper@example.com" />
  <HelpBlock>We send one curriculum update per week.</HelpBlock>
</FormGroup>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="form-group">
  <label class="form-label" for="email">Email address</label>
  <input class="input" id="email" type="email" placeholder="camper@example.com" />
  <p class="form-help">We send one curriculum update per week.</p>
</div>`}
  />
</PlaygroundCard>
