---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { SidebarLayout as SidebarLayoutCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='sidebar-layout'
  slug='SidebarLayout'
  title='Sidebar layout'
  previewStacked
  description='Header + left rail + main — the curriculum chrome shape.'
  source='layouts/SidebarLayout.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <SidebarLayoutCmp
      style={{
        width: '100%',
        maxWidth: '680px',
        margin: '0 auto',
        border: '1px solid var(--border-strong)',
        height: '320px',
        minHeight: '0'
      }}
    >
      <header
        class='sidebar-layout__header'
        style={{
          background: 'var(--background-tertiary)',
          padding: '10px 14px',
          fontFamily: 'var(--font-mono)',
          fontSize: '13px'
        }}
      >
        Header
      </header>
      <div
        class='sidebar-layout__body'
        style={{ display: 'flex', height: '100%' }}
      >
        <aside
          class='sidebar-layout__aside'
          style={{
            width: '160px',
            background: 'var(--background-secondary)',
            padding: '12px',
            fontSize: '13px'
          }}
        >
          Sidebar
        </aside>
        <main
          class='sidebar-layout__main'
          style={{ flex: '1', padding: '16px', fontSize: '13px' }}
        >
          Main content
        </main>
      </div>
    </SidebarLayoutCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { SidebarLayout, Sidebar, Navbar } from '@freecodecamp/uikit';

<SidebarLayout
  header={<Navbar … />}
  aside={<Sidebar … />}
>
  {children}
</SidebarLayout>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="sidebar-layout">
  <header class="sidebar-layout__header">…</header>
  <div class="sidebar-layout__body">
    <aside class="sidebar-layout__aside">…</aside>
    <main class="sidebar-layout__main">…</main>
  </div>
</div>`}
  />
</PlaygroundCard>
