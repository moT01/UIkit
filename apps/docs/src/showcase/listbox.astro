---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { ListboxDemo } from './_islands/ListboxDemo';
---

<PlaygroundCard
  id='listbox'
  slug='Listbox'
  title='Listbox'
  previewStacked
  description='Persistent selection list — keyboard navigable, single or multi-select.'
  source='navigation/Listbox.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/listbox/'
>
  <Fragment slot='preview'>
    <ListboxDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Listbox } from '@freecodecamp/uikit';
import { useState } from 'react';

const ITEMS = [
  { value: 'frontend', label: 'Frontend' },
  { value: 'backend',  label: 'Backend' }
];

const [value, setValue] = useState<string | string[]>('frontend');

<Listbox items={ITEMS} value={value} onValueChange={setValue} />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<ul class="listbox" role="listbox">
  <li class="listbox__option" role="option" aria-selected="true">Responsive Web Design</li>
  <li class="listbox__option" role="option">JavaScript Algorithms</li>
</ul>`}
  />
</PlaygroundCard>
