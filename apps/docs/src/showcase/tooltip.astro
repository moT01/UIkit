---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Tooltip, Button } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='tooltip'
  slug='Tooltip'
  title='Tooltip'
  description='Contextual hint on hover or focus — keep to 80 chars.'
  source='overlays/Tooltip.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/tooltip/'
>
  <Fragment slot='preview'>
    <Tooltip
      client:idle
      content='Runs the public test suite against your code.'
    >
      <Button>Run tests</Button>
    </Tooltip>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Tooltip, Button } from '@freecodecamp/uikit';

<Tooltip content="Runs the public test suite against your code.">
  <Button>Run tests</Button>
</Tooltip>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<span class="tip" data-tip="Runs the public test suite against your code.">
  <button class="btn">Run tests</button>
</span>`}
  />
</PlaygroundCard>
