---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { HelpBlock as HelpBlockCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='help-block'
  slug='HelpBlock'
  title='Help block'
  previewStacked
  description='Field-level guidance — neutral, success, or error tone.'
  source='forms/HelpBlock.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <div style='max-width:420px;margin:0 auto;display:grid;gap:14px;'>
      <HelpBlockCmp>We send one curriculum update per week.</HelpBlockCmp>
      <HelpBlockCmp variant='success'>Username available.</HelpBlockCmp>
      <HelpBlockCmp variant='error'>Username already in use.</HelpBlockCmp>
    </div>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { HelpBlock } from '@freecodecamp/uikit';

<HelpBlock>We send one curriculum update per week.</HelpBlock>
<HelpBlock variant="success">Username available.</HelpBlock>
<HelpBlock variant="error">Username already in use.</HelpBlock>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<p class="form-help">We send one curriculum update per week.</p>
<p class="form-help form-help--success">Username available.</p>
<p class="form-help form-help--error">Username already in use.</p>`}
  />
</PlaygroundCard>
