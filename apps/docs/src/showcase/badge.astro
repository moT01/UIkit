---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Badge as BadgeCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='badge'
  slug='Badge'
  title='Badge'
  description='Inline status chip — sparingly. Max 2 per row.'
  source='primitives/Badge.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <BadgeCmp>Default</BadgeCmp>
    <BadgeCmp variant='success'>Passed</BadgeCmp>
    <BadgeCmp variant='warning'>In review</BadgeCmp>
    <BadgeCmp variant='danger'>Failed</BadgeCmp>
    <BadgeCmp variant='info'>Preview</BadgeCmp>
    <BadgeCmp variant='purple'>New</BadgeCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Badge } from '@freecodecamp/uikit';

<Badge>Default</Badge>
<Badge variant="success">Passed</Badge>
<Badge variant="warning">In review</Badge>
<Badge variant="danger">Failed</Badge>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<span class="badge badge--success">Passed</span>
<span class="badge badge--warning">In review</span>
<span class="badge badge--danger">Failed</span>`}
  />
</PlaygroundCard>
