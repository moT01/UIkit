---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Switch as SwitchCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='switch'
  slug='Switch'
  title='Switch'
  description='For settings that take effect immediately — theme, audio, keybinds.'
  source='forms/Switch.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/switch/'
>
  <Fragment slot='preview'>
    <SwitchCmp client:idle defaultChecked label='Keyboard shortcuts' />
    <SwitchCmp client:idle label='Sound effects' />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Switch } from '@freecodecamp/uikit';

<Switch defaultChecked label="Keyboard shortcuts" />
<Switch label="Sound effects" />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<label class="switch">
  <input type="checkbox" checked />
  <span class="switch__track"><span class="switch__thumb"></span></span>
  <span class="switch__label">Keyboard shortcuts</span>
</label>`}
  />
</PlaygroundCard>
