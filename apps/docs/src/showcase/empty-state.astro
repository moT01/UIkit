---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { EmptyState as EmptyStateCmp, Button } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='empty-state'
  slug='EmptyState'
  title='Empty state'
  previewStacked
  description='No-data placeholder with title, description, and a primary action.'
  source='data-display/EmptyState.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <EmptyStateCmp
      title='No certifications yet'
      description='Pick a track and complete five projects to claim your first cert.'
      style={{ maxWidth: '480px', margin: '0 auto' }}
    >
      <Button variant='cta'>Browse curriculum →</Button>
    </EmptyStateCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { EmptyState, Button } from '@freecodecamp/uikit';

<EmptyState
  title="No certifications yet"
  description="Pick a track and complete five projects."
  action={<Button variant="cta">Browse curriculum →</Button>}
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="empty-state">
  <p class="empty-state__title">No certifications yet</p>
  <p class="empty-state__description">Pick a track…</p>
  <div class="empty-state__action"><a class="btn btn--cta">Browse →</a></div>
</div>`}
  />
</PlaygroundCard>
