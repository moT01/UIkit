---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { ToastDemo } from './_islands/ToastDemo';
---

<PlaygroundCard
  id='toast'
  slug='Toast'
  title='Toast'
  previewStacked
  description='Transient status surface — Ark UI toaster machine, reduced-motion aware.'
  source='overlays/Toast.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <ToastDemo client:load />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Toast, Toaster, createToaster } from '@freecodecamp/uikit';

// 1) Static — render Toast directly (the showcase variant).
<Toast variant='success' title='Saved' description='Synced.' />

// 2) Dynamic — drive a stack via createToaster + <Toaster>.
const toaster = createToaster({});

<Toaster toaster={toaster} />
toaster.create({ title: 'Saved', type: 'success' });`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="toaster">
  <div class="toast toast--success">
    <div class="toast__title">Saved</div>
    <div class="toast__description">Your progress is synced.</div>
    <button class="toast__close">×</button>
  </div>
</div>`}
  />
</PlaygroundCard>
