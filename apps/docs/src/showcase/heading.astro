---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Heading } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='heading'
  slug='Heading'
  title='Heading'
  previewStacked
  description='Headline primitive — independent of HTML level. Five visual sizes; tag chosen for outline.'
  source='primitives/Heading.tsx'
  status='stable'
  since='1.0.0'
  tokens={['--fs-display', '--fs-xl', '--fs-lg', '--fs-md']}
>
  <Fragment slot='preview'>
    <div style='max-width:560px;margin:0 auto;display:grid;gap:14px;'>
      <Heading level={1} size='display'>Command-line Chic.</Heading>
      <Heading level={2} size='xl'>Ship interfaces.</Heading>
      <Heading level={3} size='lg'>Composable primitives.</Heading>
      <Heading level={4} size='md'>Flat surfaces.</Heading>
      <Heading level={5} size='sm'>Square corners.</Heading>
    </div>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Heading } from '@freecodecamp/uikit';

<Heading level={1} size="display">Command-line Chic.</Heading>
<Heading level={2} size="xl">Ship interfaces.</Heading>
<Heading level={3} size="lg">Composable primitives.</Heading>
<Heading level={4} size="md">Flat surfaces.</Heading>
<Heading level={5} size="sm">Square corners.</Heading>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<h1 class="heading heading--display">Command-line Chic.</h1>
<h2 class="heading heading--xl">Ship interfaces.</h2>
<h3 class="heading heading--lg">Composable primitives.</h3>`}
  />
</PlaygroundCard>
