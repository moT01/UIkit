---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { FormGroup, Textarea, HelpBlock } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='textarea'
  slug='Textarea'
  title='Textarea'
  previewStacked
  description='Multi-line text control with mono variant for code snippets.'
  source='forms/Textarea.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FormGroup style={{ maxWidth: '520px', margin: '0 auto' }}>
      <label class='form-label' for='bio-demo'>Bio</label>
      <Textarea
        id='bio-demo'
        rows={3}
        placeholder='What are you learning right now?'
      />
      <HelpBlock>Markdown supported. 240 character cap.</HelpBlock>
    </FormGroup>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Textarea } from '@freecodecamp/uikit';

<Textarea
  id="bio"
  rows={3}
  placeholder="What are you learning right now?"
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<textarea class="input input--textarea" id="bio" rows="3"></textarea>`}
  />
</PlaygroundCard>
