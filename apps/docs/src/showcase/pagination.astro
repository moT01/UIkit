---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { PaginationDemo } from './_islands/PaginationDemo';
---

<PlaygroundCard
  id='pagination'
  slug='Pagination'
  title='Pagination'
  previewStacked
  description='Page selector — Ark UI pagination machine, keyboard navigable.'
  source='navigation/Pagination.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <PaginationDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Pagination } from '@freecodecamp/uikit';

<Pagination
  count={120}
  pageSize={10}
  page={2}
  onPageChange={(page) => setPage(page)}
/>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<nav class="pagination" aria-label="Pagination">
  <ul class="pagination__list">
    <li><button class="pagination__btn" disabled>‹</button></li>
    <li><button class="pagination__btn" aria-current="page">2</button></li>
    <li><span class="pagination__ellipsis">…</span></li>
  </ul>
</nav>`}
  />
</PlaygroundCard>
