---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Panel } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='panel'
  slug='Panel'
  title='Panel'
  previewStacked
  description='Borderless surface-two container — sidebars, inspectors, nested regions.'
  source='data-display/Panel.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <Panel title='Editor hints' style={{ maxWidth: '520px', margin: '0 auto' }}>
      Your code runs against the first test each time you save. Open the console
      tab to inspect logs.
    </Panel>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Panel } from '@freecodecamp/uikit';

<Panel title="Editor hints">
  Your code runs against the first test each time you save.
</Panel>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="panel">
  <p class="panel__heading">Editor hints</p>
  <p class="panel__body">Your code runs against the first test each time you save.</p>
</div>`}
  />
</PlaygroundCard>
