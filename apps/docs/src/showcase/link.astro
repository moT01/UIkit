---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Link } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='link'
  slug='Link'
  title='Link'
  description='Inline links carry the highlight accent and thicken on hover.'
  source='primitives/Link.tsx'
  status='stable'
  since='1.0.0'
  tokens={['--highlight-color']}
>
  <Fragment slot='preview'>
    <p style='margin:0;font-size:18px;color:var(--foreground-secondary)'>
      Explore the <Link href='#tokens'>token layer</Link> to recolor every component
      at once.
    </p>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Link } from '@freecodecamp/uikit';

<p>Explore the <Link href="#tokens">token layer</Link> to recolor every component.</p>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<a class="fcc-link" href="#tokens">token layer</a>`}
  />
</PlaygroundCard>
