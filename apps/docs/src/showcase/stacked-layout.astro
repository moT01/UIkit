---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { StackedLayout as StackedLayoutCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='stacked-layout'
  slug='StackedLayout'
  title='Stacked layout'
  previewStacked
  description='Header + main + footer — the marketing/news chrome shape.'
  source='layouts/StackedLayout.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <StackedLayoutCmp
      style={{
        width: '100%',
        maxWidth: '680px',
        margin: '0 auto',
        border: '1px solid var(--border-strong)',
        height: '320px',
        minHeight: '0',
        display: 'flex',
        flexDirection: 'column'
      }}
    >
      <header
        class='stacked-layout__header'
        style={{
          background: 'var(--background-tertiary)',
          padding: '10px 14px',
          fontFamily: 'var(--font-mono)',
          fontSize: '13px'
        }}
      >
        Header
      </header>
      <main
        class='stacked-layout__main'
        style={{ flex: '1', padding: '16px', fontSize: '13px' }}
      >
        Main content
      </main>
      <footer
        class='stacked-layout__footer'
        style={{
          background: 'var(--background-secondary)',
          padding: '10px 14px',
          fontFamily: 'var(--font-mono)',
          fontSize: '12px',
          color: 'var(--foreground-muted)'
        }}
      >
        Footer
      </footer>
    </StackedLayoutCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { StackedLayout, Navbar } from '@freecodecamp/uikit';

<StackedLayout
  header={<Navbar … />}
  footer={<footer>…</footer>}
>
  {children}
</StackedLayout>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="stacked-layout">
  <header class="stacked-layout__header">…</header>
  <main class="stacked-layout__main">…</main>
  <footer class="stacked-layout__footer">…</footer>
</div>`}
  />
</PlaygroundCard>
