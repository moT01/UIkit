---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Divider, Text } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='divider'
  slug='Divider'
  title='Divider'
  previewStacked
  description='Hairline rule. Solid or dashed; horizontal or vertical.'
  source='primitives/Divider.tsx'
  status='stable'
  since='1.0.0'
  tokens={['--border-strong']}
>
  <Fragment slot='preview'>
    <div style='max-width:480px;margin:0 auto;display:grid;gap:16px;'>
      <Text size='sm' tone='muted'>Solid</Text>
      <Divider />
      <Text size='sm' tone='muted'>Dashed</Text>
      <Divider variant='dashed' />
      <div
        style='display:flex;align-items:center;gap:14px;font-family:var(--font-mono);font-size:13px;color:var(--foreground-muted);'
      >
        <span>kbd</span>
        <Divider orientation='vertical' style={{ height: '18px' }} />
        <span>shortcut</span>
      </div>
    </div>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Divider } from '@freecodecamp/uikit';

<Divider />
<Divider variant="dashed" />
<Divider orientation="vertical" />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<hr class="divider" />
<hr class="divider divider--dashed" />
<span class="divider divider--vertical"></span>`}
  />
</PlaygroundCard>
