---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Alert } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='alert'
  slug='Alert'
  title='Alert'
  previewStacked
  description='Full-width status surface for page-level state — saved, failed, queued.'
  source='data-display/Alert.tsx'
  status='stable'
  since='1.0.0'
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/alert/'
>
  <Fragment slot='preview'>
    <Alert variant='success'>All 28 tests pass. Next challenge unlocked.</Alert>
    <Alert variant='warning'>You have one unsaved edit.</Alert>
    <Alert variant='danger'>Sign-in failed — check your email address.</Alert>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Alert } from '@freecodecamp/uikit';

<Alert variant="success">All 28 tests pass. Next challenge unlocked.</Alert>
<Alert variant="warning">You have one unsaved edit.</Alert>
<Alert variant="danger">Sign-in failed — check your email address.</Alert>`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<div class="alert alert--info">All 28 tests pass.</div>
<div class="alert alert--warning">You have one unsaved edit.</div>
<div class="alert alert--danger">Sign-in failed — check your email address.</div>`}
  />
</PlaygroundCard>
