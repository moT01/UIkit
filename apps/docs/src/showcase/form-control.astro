---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { FormControl } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='form-control'
  slug='FormControl'
  title='Form control'
  previewStacked
  description='Low-level text control — no label wrapper, for custom layouts.'
  source='forms/FormControl.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FormControl
      placeholder='Search the curriculum'
      style={{ maxWidth: '420px' }}
    />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { FormControl } from '@freecodecamp/uikit';

<FormControl placeholder="Search the curriculum" />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<input class="input" placeholder="Search the curriculum" />`}
  />
</PlaygroundCard>
