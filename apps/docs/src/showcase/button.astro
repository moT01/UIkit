---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Button as ButtonCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='button'
  slug='Button'
  title='Button'
  description='The workhorse. 3px square border, inverted fill on primary, no shadow.'
  source='primitives/Button.tsx'
  status='stable'
  since='1.0.0'
  tokens={['--cta-background', '--cta-foreground', '--foreground-primary']}
  a11yPattern='https://www.w3.org/WAI/ARIA/apg/patterns/button/'
>
  <Fragment slot='preview'>
    <ButtonCmp variant='cta'>Start curriculum</ButtonCmp>
    <ButtonCmp>Secondary</ButtonCmp>
    <ButtonCmp variant='danger'>Dangerous</ButtonCmp>
    <ButtonCmp variant='ghost'>Ghost</ButtonCmp>
    <ButtonCmp size='sm'>Small</ButtonCmp>
    <ButtonCmp size='lg'>Large</ButtonCmp>
    <ButtonCmp disabled>Disabled</ButtonCmp>
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Button } from '@freecodecamp/uikit';

export function Actions() {
  return (
    <div style={{ display: 'flex', gap: 12 }}>
      <Button variant="cta">Start curriculum</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="danger">Dangerous</Button>
      <Button variant="ghost">Ghost</Button>
    </div>
  );
}`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<button class="btn btn--cta">Start curriculum</button>
<button class="btn">Secondary</button>
<button class="btn btn--danger">Dangerous</button>
<button class="btn btn--ghost">Ghost</button>`}
  />
</PlaygroundCard>
