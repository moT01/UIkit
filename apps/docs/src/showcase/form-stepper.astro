---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { FormStepperDemo } from './_islands/FormStepperDemo';
---

<PlaygroundCard
  id='form-stepper'
  slug='FormStepper'
  title='Form stepper'
  previewStacked
  previewPlain
  description='Multi-step form progress — Ark UI machine, keyboard navigable.'
  source='forms/FormStepper.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <FormStepperDemo client:visible />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { FormStepper } from '@freecodecamp/uikit';
import { useState } from 'react';

const STEPS = [
  { id: 'account',  label: 'Account',  description: 'Email + handle' },
  { id: 'goals',    label: 'Goals',    description: 'What to learn first' },
  { id: 'confirm',  label: 'Confirm',  description: 'Review + start' }
];

const [current, setCurrent] = useState('account');

<FormStepper steps={STEPS} current={current} onStepChange={setCurrent} />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<ol class="form-stepper">
  <li class="form-stepper__step" aria-current="step">…</li>
</ol>`}
  />
</PlaygroundCard>
