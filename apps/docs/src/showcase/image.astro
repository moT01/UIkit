---
import PlaygroundCard from '../components/site/PlaygroundCard.astro';
import { Code } from 'astro/components';
import { Image as ImageCmp } from '@freecodecamp/uikit';
---

<PlaygroundCard
  id='image'
  slug='Image'
  title='Image'
  previewStacked
  description='Responsive image wrapper with built-in aspect caption and alt enforcement.'
  source='primitives/Image.tsx'
  status='stable'
  since='1.0.0'
>
  <Fragment slot='preview'>
    <ImageCmp
      src='/brand/fcc-secondary.svg'
      alt='freeCodeCamp mark'
      caption='freeCodeCamp mark on surface-two'
      style={{
        background: 'var(--background-secondary)',
        padding: '24px',
        maxWidth: '480px',
        margin: '0 auto'
      }}
    />
  </Fragment>
  <Code
    slot='react'
    lang='tsx'
    code={`import { Image } from '@freecodecamp/uikit';

<Image src="/brand/fcc-secondary.svg" alt="freeCodeCamp mark" caption="freeCodeCamp mark" />`}
  />
  <Code
    slot='html'
    lang='html'
    code={`<figure>
  <img class="img--responsive" src="/brand/fcc-secondary.svg" alt="freeCodeCamp mark" />
  <figcaption>freeCodeCamp mark</figcaption>
</figure>`}
  />
</PlaygroundCard>
