---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/site/AppHeader.astro';
import AppSidebar from '../../components/site/AppSidebar.astro';
import ComponentCard from '../../components/site/ComponentCard.astro';

type Category =
  | 'primitive'
  | 'form'
  | 'overlay'
  | 'navigation'
  | 'data-display'
  | 'layout';

interface CategorySpec {
  readonly id: Category;
  readonly label: string;
  readonly description: string;
}

const CATEGORIES: readonly CategorySpec[] = [
  {
    id: 'primitive',
    label: 'Primitives',
    description: 'The smallest atoms — buttons, links, text, divider.'
  },
  {
    id: 'form',
    label: 'Forms',
    description:
      'Controls and the wrappers that keep labels, help, and errors wired together.'
  },
  {
    id: 'navigation',
    label: 'Navigation',
    description: 'Chrome for moving between pages and inside pages.'
  },
  {
    id: 'overlay',
    label: 'Overlays',
    description:
      'Layers that float above page content — modal, dropdown, toast, tooltip.'
  },
  {
    id: 'data-display',
    label: 'Data display',
    description: 'Feedback primitives, cards, tables, and description lists.'
  },
  {
    id: 'layout',
    label: 'Layouts',
    description: 'Page shells — sidebar, stacked, auth.'
  }
];

const entries = await getCollection('components');
const sorted = entries
  .slice()
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const byCategory = new Map<Category, typeof sorted>();
for (const entry of sorted) {
  const list = byCategory.get(entry.data.category) ?? [];
  list.push(entry);
  byCategory.set(entry.data.category, list);
}
---

<BaseLayout
  title='freeCodeCamp UIKit — Components'
  description='Command-line Chic components. Dark-first, flat, square. React and vanilla.'
>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='app__main' id='content'>
        <header class='components-index__header'>
          <p class='components-index__eyebrow'>Components</p>
          <h1 class='components-index__title'>Every brick, every layer</h1>
          <p class='components-index__lede'>
            Grouped by role. Pick a component to see props, accessibility
            guidance, and the full storybook variant.
          </p>
        </header>

        {
          sorted.length === 0 ? (
            <div class='components-index__empty'>
              <p>
                No components in the collection yet. Wave 2 is under way —
                <a href='/guides/copy-paste'>copy-paste guide</a> in the
                meantime.
              </p>
            </div>
          ) : (
            CATEGORIES.map(cat => {
              const list = byCategory.get(cat.id) ?? [];
              if (list.length === 0) return null;
              return (
                <section class='components-index__group' id={`group-${cat.id}`}>
                  <header class='components-index__group-header'>
                    <h2 class='components-index__group-title'>{cat.label}</h2>
                    <p class='components-index__group-description'>
                      {cat.description}
                    </p>
                  </header>
                  <ul class='components-index__grid' role='list'>
                    {list.map(entry => (
                      <li class='components-index__card'>
                        <ComponentCard entry={entry} />
                      </li>
                    ))}
                  </ul>
                </section>
              );
            })
          )
        }
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .components-index__header {
    padding: var(--space-6, 2.5rem) var(--space-5, 2rem);
    border-bottom: 2px solid var(--background-tertiary, #2a2a40);
  }
  .components-index__eyebrow {
    font-family: var(--font-mono);
    text-transform: lowercase;
    letter-spacing: 0.08em;
    color: var(--cta-background, #f1be32);
    margin: 0 0 0.5rem;
  }
  .components-index__title {
    font-size: 2.25rem;
    margin: 0 0 0.75rem;
  }
  .components-index__lede {
    max-width: 52ch;
    color: var(--foreground-secondary, #dfdfe2);
    margin: 0;
  }
  .components-index__empty {
    padding: var(--space-6, 2.5rem) var(--space-5, 2rem);
    color: var(--foreground-secondary, #dfdfe2);
  }
  .components-index__group {
    padding: var(--space-5, 2rem);
    border-bottom: 1px dashed var(--background-tertiary, #2a2a40);
  }
  .components-index__group:last-of-type {
    border-bottom: 0;
  }
  .components-index__group-header {
    margin-bottom: var(--space-4, 1.5rem);
  }
  .components-index__group-title {
    font-size: 1.5rem;
    margin: 0 0 0.25rem;
    color: var(--foreground-primary, #fff);
  }
  .components-index__group-description {
    color: var(--foreground-secondary, #dfdfe2);
    margin: 0;
    max-width: 52ch;
  }
  .components-index__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4, 1.5rem);
  }
  .components-index__card .card {
    display: block;
    border: 2px solid var(--background-tertiary, #2a2a40);
    padding: var(--space-4, 1.5rem);
    background: var(--background-secondary, #1b1b32);
    color: inherit;
    text-decoration: none;
    transition: border-color 120ms
      var(--ease-snap, cubic-bezier(0.2, 0.8, 0.2, 1));
  }
  .components-index__card .card:hover,
  .components-index__card .card:focus-visible {
    border-color: var(--cta-background, #f1be32);
  }
  .card__eyebrow {
    font-family: var(--font-mono);
    color: var(--cta-background, #f1be32);
    margin: 0 0 0.5rem;
    letter-spacing: 0.04em;
  }
  .card__title {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
  }
  .card__summary {
    color: var(--foreground-secondary, #dfdfe2);
    margin: 0 0 0.75rem;
  }
  .card__meta {
    display: flex;
    gap: var(--space-2, 0.75rem);
    align-items: center;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .chip {
    padding: 0.125rem 0.5rem;
    border: 1px solid currentColor;
  }
  .chip--stable {
    color: var(--semantic-success, #55b848);
  }
  .chip--beta {
    color: var(--semantic-warning, #f1be32);
  }
  .chip--planned {
    color: var(--foreground-secondary, #dfdfe2);
  }
  .card__since {
    color: var(--foreground-secondary, #dfdfe2);
  }
</style>
