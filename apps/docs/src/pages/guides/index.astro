---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/site/AppHeader.astro';
import AppSidebar from '../../components/site/AppSidebar.astro';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title='Guides — freeCodeCamp UIKit'
  description='Per-package install, Tailwind wiring, CDN tags, copy-paste markup, React recipes, and the v1.0 migration plan.'
>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='content' tabindex='-1'>
        <div class='content__inner content__inner--prose'>
          <header class='prose-hero'>
            <p class='prose-hero__eyebrow'>Guides</p>
            <h1 class='prose-hero__title'>Build with the UIKit.</h1>
            <p class='prose-hero__lede'>
              Six surfaces. Pick the one that matches your stack. Each guide
              stands alone — the install guide is enough for most teams.
            </p>
          </header>

          <ul class='guides-index' role='list'>
            {
              guides.map(g => (
                <li>
                  <a class='guides-index__card' href={`/guides/${g.id}`}>
                    <p class='guides-index__eyebrow'>{g.data.eyebrow}</p>
                    <p class='guides-index__title'>{g.data.title}</p>
                    <p class='guides-index__summary'>{g.data.summary}</p>
                    <p class='guides-index__cta'>
                      Read <span aria-hidden='true'>→</span>
                    </p>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .guides-index {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 14px;
  }
  .guides-index__card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 20px;
    background: var(--background-secondary);
    border: 1px solid var(--border-strong);
    color: var(--foreground-primary);
    text-decoration: none;
    transition:
      border-color var(--dur-fast) var(--ease-snap),
      background-color var(--dur-fast) var(--ease-snap);
  }
  .guides-index__card:hover {
    border-color: var(--cta-background);
    background: var(--background-tertiary);
  }
  .guides-index__eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--foreground-muted);
  }
  .guides-index__title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
  }
  .guides-index__summary {
    margin: 0;
    font-size: 15px;
    color: var(--foreground-secondary);
    line-height: 1.5;
  }
  .guides-index__cta {
    margin: 8px 0 0;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cta-background);
  }
</style>
