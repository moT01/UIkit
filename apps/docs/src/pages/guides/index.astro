---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/site/AppHeader.astro';
import AppSidebar from '../../components/site/AppSidebar.astro';
---

<BaseLayout title='freeCodeCamp UIKit — Guides'>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='content' tabindex='-1'>
        <div class='content__inner'>
          <section class='hero' id='introduction'>
            <p class='hero__kicker'>Guides</p>
            <h1 class='hero__title'>Ship UIKit however you like.</h1>
            <p class='hero__lede'>
              Two usage patterns, no lock-in. Pull the kit off the CDN for the
              fastest path, or vendor the compiled files when you need to own
              them. Both routes get you identical output.
            </p>
          </section>

          <section class='section' id='patterns'>
            <p class='section__eyebrow'>Pick a pattern</p>
            <h2 class='section__title'>Two ways in</h2>

            <div class='guide-grid'>
              <a class='guide-card' href='/guides/cdn'>
                <p class='guide-card__kicker'>Pattern 01</p>
                <h3 class='guide-card__title'>Use via CDN</h3>
                <p class='guide-card__lede'>
                  One <code>@import</code> line. Fonts resolve automatically. Works
                  in any React app, Astro site, or Windmill raw app.
                </p>
                <p class='guide-card__cta'>Open guide →</p>
              </a>

              <a class='guide-card' href='/guides/copy-paste'>
                <p class='guide-card__kicker'>Pattern 02</p>
                <h3 class='guide-card__title'>Copy &amp; vendor</h3>
                <p class='guide-card__lede'>
                  Ship the compiled bundle with your app, or paste the source
                  CSS and components directly into your repo. No network
                  dependency.
                </p>
                <p class='guide-card__cta'>Open guide →</p>
              </a>
            </div>
          </section>

          <section class='section' id='principles'>
            <p class='section__eyebrow'>Ground rules</p>
            <h2 class='section__title'>What you always get</h2>
            <ul class='guide-list'>
              <li>
                <strong>Flat, square, dark-first.</strong> No shadows, no rounded
                corners, AA+ contrast.
              </li>
              <li>
                <strong>CSS variables own the palette.</strong> Toggle <code
                  >.light-palette</code
                > on <code>&lt;html&gt;</code> and the whole kit re-themes.
              </li>
              <li>
                <strong>React + vanilla stay in sync.</strong> Every React component
                renders the same BEM class strings the vanilla snippets use.
              </li>
              <li>
                <strong>BSD-3-Clause licensed.</strong> Copy, fork, rename tokens.
                The repo doesn't assume you keep it unchanged.
              </li>
            </ul>
          </section>

          <footer class='footer'>
            <p>
              freeCodeCamp UIKit · <a href='/'>Back to components</a> · <a
                href='https://github.com/freeCodeCamp/ui'>Source</a
              >
            </p>
          </footer>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin: 8px 0 24px;
  }
  @media (max-width: 700px) {
    .guide-grid {
      grid-template-columns: 1fr;
    }
  }
  .guide-card {
    display: block;
    padding: 24px;
    background: var(--background-secondary);
    border: 1px solid var(--border-strong);
    color: var(--foreground-primary);
    text-decoration: none;
    transition:
      border-color 120ms,
      background-color 120ms;
  }
  .guide-card:hover {
    border-color: var(--cta-background);
    background: var(--background-tertiary);
  }
  .guide-card__kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--foreground-muted);
    margin: 0 0 8px;
  }
  .guide-card__title {
    font-size: var(--fs-xl);
    margin: 0 0 8px;
  }
  .guide-card__lede {
    font-size: var(--fs-md);
    color: var(--foreground-secondary);
    margin: 0 0 16px;
    max-width: 46ch;
  }
  .guide-card__cta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cta-background);
    margin: 0;
  }
  .guide-list {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 72ch;
    color: var(--foreground-secondary);
    font-size: 17px;
    line-height: 1.55;
  }
  .guide-list strong {
    color: var(--foreground-primary);
  }
  .guide-block {
    background: var(--background-secondary);
    border: 1px solid var(--border-strong);
    padding: 20px 24px;
    margin: 0 0 24px;
  }
  .guide-block__title {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--foreground-muted);
    margin: 0 0 12px;
  }
  .guide-pre {
    background: var(--editor-background);
    color: var(--foreground-tertiary);
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.55;
    overflow-x: auto;
    margin: 0 0 12px;
    white-space: pre;
  }
  .guide-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--foreground-muted);
    margin: 0;
  }
  .guide-toc {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin: 0 0 24px;
    padding: 12px 16px;
    border: 1px dashed var(--border-strong);
  }
  .guide-toc a {
    font-family: var(--font-mono);
    font-size: 13px;
  }
</style>
