---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppHeader from '../../components/site/AppHeader.astro';
import AppSidebar from '../../components/site/AppSidebar.astro';
---

<BaseLayout title='freeCodeCamp UIKit — Copy & vendor'>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='content' tabindex='-1'>
        <div class='content__inner'>
          <section class='hero' id='introduction'>
            <p class='hero__kicker'>Pattern 02 · Copy &amp; vendor</p>
            <h1 class='hero__title'>Own the files.</h1>
            <p class='hero__lede'>
              When the CDN isn't available, isn't allowed, or you want the kit
              under version control, pull the files into your own repo. Four
              tiers — same visual result, increasing level of ownership.
            </p>
            <nav class='guide-toc' aria-label='On this page'>
              <a href='#tier-1'>1 · Vendor the compiled bundle</a>
              <a href='#tier-2'>2 · Paste the source CSS</a>
              <a href='#tier-3'>3 · Paste individual snippets</a>
              <a href='#tier-4'>4 · Copy React components</a>
            </nav>
          </section>

          <section class='section' id='tier-1'>
            <p class='section__eyebrow'>Tier 01 · lightest fork</p>
            <h2 class='section__title'>Vendor the compiled bundle</h2>
            <p class='section__lede'>
              Download the minified CSS and fonts and commit them to your repo.
              Your app imports a local path; no runtime dependency on
              <code>cdn.freecodecamp.org</code>.
            </p>

            <div class='guide-block'>
              <p class='guide-block__title'>1 · Grab the files</p>
              <pre
                class='guide-pre'><code>pnpm dlx degit freeCodeCamp/ui/dist-cdn/uikit your-app/public/uikit</code></pre>
              <p class='guide-meta'>
                Or clone the repo and run <code>pnpm build:cdn</code>; the
                output lives in <code>dist-cdn/uikit/</code>.
              </p>
            </div>

            <div class='guide-block'>
              <p class='guide-block__title'>2 · Import from your app</p>
              <pre
                class='guide-pre'><code>@import url("/uikit/styles.min.css");</code></pre>
              <p class='guide-meta'>
                Fonts resolve through the relative <code>./fonts/</code> path inside
                the bundle — nothing else to wire up.
              </p>
            </div>
          </section>

          <section class='section' id='tier-2'>
            <p class='section__eyebrow'>Tier 02</p>
            <h2 class='section__title'>Paste the source CSS</h2>
            <p class='section__lede'>
              Skip the minified bundle entirely. Copy <code
                >src/styles/tokens.css</code
              >
              and <code>src/styles/components.css</code> into your own stylesheet
              folder. Import them in your entry CSS.
            </p>
            <div class='guide-block'>
              <p class='guide-block__title'>index.css</p>
              <pre
                class='guide-pre'><code>@import "./uikit/tokens.css";
@import "./uikit/components.css";</code></pre>
              <p class='guide-meta'>
                Update the <code>@font-face</code> URLs in <code
                  >tokens.css</code
                > so they point at wherever you ship the fonts.
              </p>
            </div>
          </section>

          <section class='section' id='tier-3'>
            <p class='section__eyebrow'>Tier 03</p>
            <h2 class='section__title'>Paste individual snippets</h2>
            <p class='section__lede'>
              Want only the button and the card? Copy just those rule blocks out
              of <code>components.css</code>, plus the CSS variables they depend
              on. Each rule is independent — nothing cascades across components.
            </p>
            <ul class='guide-list'>
              <li>
                Variables the kit ships from <code>tokens.css</code>: palette, <code
                  >--font-sans</code
                >, <code>--font-mono</code>, <code>--fs-*</code>, <code
                  >--space-*</code
                >.
              </li>
              <li>
                Each component block is labelled (<code
                  >/* ---------- Button ---------- */</code
                >) so you can grep for it.
              </li>
              <li>
                Pull the matching HTML snippet from the storybook's Vanilla tab.
              </li>
            </ul>
          </section>

          <section class='section' id='tier-4'>
            <p class='section__eyebrow'>Tier 04 · deepest fork</p>
            <h2 class='section__title'>Copy React components</h2>
            <p class='section__lede'>
              Every <code>.tsx</code> file under <code
                >src/components/react/</code
              >
              is a thin wrapper around the BEM class names. Drop one into your repo
              and pair it with the matching CSS — the component doesn't know or care
              where the styles come from.
            </p>
            <div class='guide-block'>
              <p class='guide-block__title'>Example</p>
              <pre
                class='guide-pre'><code>// your-app/src/ui/Button.tsx  (copied from UIKit)
import &#123; Button &#125; from "./Button";

&lt;Button variant="cta" isLoading&gt;Save&lt;/Button&gt;
// renders: &lt;button class="btn btn--cta" aria-busy="true"&gt;&lt;span class="btn__spinner"&gt;&lt;/span&gt;Save&lt;/button&gt;</code></pre>
            </div>
            <div class='callout callout--note'>
              <p class='callout__label'>Theming</p>
              <p class='callout__body'>
                React components render class names only — no inline hex.
                Toggling <code>.light-palette</code> on <code>&lt;html&gt;</code
                > re-themes them identically to the vanilla snippets.
              </p>
            </div>
          </section>

          <footer class='footer'>
            <p>
              Guide · <a href='/guides'>All guides</a> · <a href='/guides/cdn'
                >← Use via CDN</a
              >
            </p>
          </footer>
        </div>
      </main>
    </div>
  </div>
</BaseLayout>
