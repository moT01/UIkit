---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/site/AppHeader.astro';
import AppSidebar from '../components/site/AppSidebar.astro';
import FoundationsBandSection from '../components/site/FoundationsBandSection.astro';
import { nav } from '../data/nav';

const showcaseModules = import.meta.glob<{ default: any }>(
  '../showcase/*.astro',
  { eager: true }
);
const slugFor = (navId: string) => navId.replace(/^cmp-/, '');
const componentForSlug = (slug: string) => {
  const mod = showcaseModules[`../showcase/${slug}.astro`];
  if (!mod) throw new Error(`No showcase file for slug "${slug}"`);
  return mod.default;
};

// Type scale: just the demo content. Sizes/line-heights live in CSS
// custom properties (`--fs-*`); the meta line reads them at runtime
// via the same TokenSwatch-style resolver pattern.
const typeScale = [
  {
    name: 'Display',
    token: '--fs-display',
    tag: 'h1',
    text: 'Command-line Chic.'
  },
  {
    name: 'Title',
    token: '--fs-2xl',
    tag: 'h2',
    text: 'Ship interfaces that feel like home.'
  },
  {
    name: 'Section',
    token: '--fs-xl',
    tag: 'h3',
    text: 'Composable primitives.'
  },
  {
    name: 'Subhead',
    token: '--fs-lg',
    tag: 'h4',
    text: 'Flat surfaces, square corners.'
  },
  {
    name: 'Lede',
    token: '--fs-md',
    tag: 'p',
    text: 'Type-heavy, shadow-free, accessible by default.'
  },
  {
    name: 'Body',
    token: '--fs-base',
    tag: 'p',
    text: 'Eighteen-pixel minimum. Never compromise the body.'
  },
  {
    name: 'Caption',
    token: '--fs-sm',
    tag: 'p',
    text: '404-ROUTE — optimized for 120ch lines of code.'
  }
];

const spacing = [0, 4, 8, 12, 16, 24, 32, 48, 64];
---

<BaseLayout
  title='freeCodeCamp UIKit — Playground'
  description='Interactive playground for every component in the freeCodeCamp UIKit — preview each surface, copy snippets, and test in light + dark.'
>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='content sidebar-layout__main' tabindex='-1'>
        <div class='content__inner'>
          <!-- ============================================================ -->
          <!-- HERO -->
          <!-- ============================================================ -->
          <section class='hero' id='introduction'>
            <p class='hero__kicker'>freeCodeCamp presents</p>
            <h1 class='hero__title'>
              <em>Command-line Chic</em>
            </h1>
            <p class='hero__lede'>
              A dark-first, token-driven, framework-agnostic UI kit by the
              freeCodeCamp team. Built for learners—by learners. Open source and
              free to use.
            </p>
            <p class='hero__hint'>
              <code>pnpm add @freecodecamp/uikit @freecodecamp/uikit-css</code>
            </p>
            <p>
              — full setup in the <a class='fcc-link' href='/handbook#install'
                >install guide</a
              >.
            </p>
            <div class='hero__actions'>
              <a class='btn btn--cta' href='/handbook#install'>Get started →</a>
              <a class='btn' href='#button'>Browse components</a>
              <a
                class='btn btn--ghost'
                href='https://github.com/freeCodeCamp/UIkit'
                target='_blank'
                rel='noreferrer noopener'>View on GitHub →</a
              >
            </div>
            <pre
              class='hero__terminal'
              aria-hidden='true'
              data-terminal><code data-terminal-body /><span class='hero__terminal-caret' data-terminal-caret>&#x2588;</span></pre>
          </section>

          <!-- ============================================================ -->
          <!-- THREE SURFACES BAND -->
          <!-- ============================================================ -->
          <section class='section surfaces-band' id='surfaces'>
            <p class='section__eyebrow'>00 · three surfaces, one system</p>
            <h2 class='section__title'>
              Pick the flavour, keep the behaviour.
            </h2>
            <ul class='surfaces' role='list'>
              <li class='surfaces__card'>
                <p class='surfaces__kicker'>01 · React</p>
                <h3 class='surfaces__title'>&lt;Button variant="cta" /&gt;</h3>
                <p class='surfaces__lede'>
                  Tree-shakeable ESM, Ark UI under the hood, React 18+ peer.
                </p>
                <pre
                  class='surfaces__code'><code>{'pnpm add @freecodecamp/uikit\nimport { Button } from \'@freecodecamp/uikit\';'}</code></pre>
              </li>
              <li class='surfaces__card'>
                <p class='surfaces__kicker'>02 · HTML</p>
                <h3 class='surfaces__title'>
                  &lt;button class="btn btn--cta"&gt;
                </h3>
                <p class='surfaces__lede'>
                  Drop-in vanilla CSS + 3 KB runtime. No framework required.
                </p>
                <pre
                  class='surfaces__code'><code>{'<link rel="stylesheet"\n  href="cdn.freecodecamp.org/uikit/styles.min.css">'}</code></pre>
              </li>
              <li class='surfaces__card'>
                <p class='surfaces__kicker'>03 · Tailwind</p>
                <h3 class='surfaces__title'>bg-cta text-fg-primary</h3>
                <p class='surfaces__lede'>
                  Preset mirrors every token; palette variants fcc-dark /
                  fcc-light.
                </p>
                <pre
                  class='surfaces__code'><code>{'// tailwind.config.js\nimport fcc from \'@freecodecamp/uikit-tailwind\';\nexport default { presets: [fcc] };'}</code></pre>
              </li>
            </ul>
          </section>

          <!-- ============================================================ -->
          <!-- FOUNDATIONS QUICKLINKS -->
          <!-- ============================================================ -->
          <section class='section' id='foundations'>
            <p class='section__eyebrow'>Foundations</p>
            <h2 class='section__title'>Start with the tokens.</h2>
            <p class='section__lede'>
              The component layer is only honest if the token layer is. Six
              pillars define how surfaces read, resize, and respond.
            </p>
            <ul class='foundations-links' role='list'>
              <li>
                <a href='/handbook#palette'
                  ><strong>Palette</strong><span
                    >Navy base · gold CTA · terminal semantics</span
                  ></a
                >
              </li>
              <li>
                <a href='/handbook#typography'
                  ><strong>Typography</strong><span
                    >Lato body · Hack-ZeroSlash mono</span
                  ></a
                >
              </li>
              <li>
                <a href='/handbook#spacing'
                  ><strong>Spacing</strong><span>8-step scale, 4 px grid</span
                  ></a
                >
              </li>
              <li>
                <a href='/handbook#iconography'
                  ><strong>Iconography</strong><span
                    >Lucide subset · 24/20/16</span
                  ></a
                >
              </li>
              <li>
                <a href='/handbook#motion'
                  ><strong>Motion</strong><span
                    >Snap · ease-out · 120–260ms</span
                  ></a
                >
              </li>
              <li>
                <a href='/handbook#voice'
                  ><strong>Voice</strong><span
                    >Direct · literal · learner-first</span
                  ></a
                >
              </li>
            </ul>
          </section>

          <!-- ============================================================ -->
          <!-- TOKENS -->
          <!-- ============================================================ -->
          <FoundationsBandSection />

          <section class='section' id='tokens'>
            <p class='section__eyebrow'>02 · type & spacing</p>
            <h2 class='section__title'>Type scale & spacing</h2>
            <p class='section__lede'>
              The body type ladder, monospaced display sizes, and the eight-step
              spacing grid every layout reaches for.
            </p>

            <h3 style='font-size:var(--fs-lg);margin:24px 0 12px;'>
              Type scale
            </h3>
            <div>
              {
                typeScale.map(t => (
                  <div class='type-sample'>
                    <p class='type-sample__meta'>
                      {t.name} · <code>{t.token}</code>
                    </p>
                    <div class='type-sample__body'>
                      {t.tag === 'h1' && <h1 style='margin:0'>{t.text}</h1>}
                      {t.tag === 'h2' && <h2 style='margin:0'>{t.text}</h2>}
                      {t.tag === 'h3' && <h3 style='margin:0'>{t.text}</h3>}
                      {t.tag === 'h4' && <h4 style='margin:0'>{t.text}</h4>}
                      {t.tag === 'p' && <p style='margin:0'>{t.text}</p>}
                    </div>
                  </div>
                ))
              }
            </div>

            <h3 style='font-size:var(--fs-lg);margin:40px 0 12px;'>Spacing</h3>
            <div class='space-grid'>
              {
                spacing.map(s => [
                  <span class='space-grid__label'>{s}px</span>,
                  <div>
                    <div
                      class='space-grid__bar'
                      style={`width:${Math.max(s, 1)}px`}
                    />
                  </div>
                ])
              }
            </div>
          </section>

          <!-- ============================================================ -->
          <!-- COMPONENT SECTION GROUPS — driven by data/nav.ts -->
          <!-- One <div class='section-group'> per nav section. The slug -->
          <!-- list inside each section drives the order of <Showcase /> -->
          <!-- components. Each showcase lives in src/showcase/<slug>.astro. -->
          <!-- ============================================================ -->
          {
            nav.map((section, index) => {
              const groupLetter = String.fromCharCode(65 + index);
              return (
                <div class='section-group' data-section-group={section.id}>
                  <header class='section-group__header'>
                    <p class='section-group__header-eyebrow'>
                      Group {groupLetter}
                    </p>
                    <h2 class='section-group__header-title'>{section.label}</h2>
                  </header>
                  {section.items.map(item => {
                    const ShowcaseComponent = componentForSlug(
                      slugFor(item.id)
                    );
                    return <ShowcaseComponent />;
                  })}
                </div>
              );
            })
          }

          <footer class='footer'>
            <p>
              freeCodeCamp UIKit · Built for freeCodeCamp campers. Released
              under the BSD-3-Clause license. <a
                href='https://github.com/freeCodeCamp/UIkit'>View source</a
              >.
            </p>
          </footer>
        </div>
      </main>
    </div>
  </div>

  <script>
    // Scroll-spy moved to `scripts/showcase-spy.client.ts` for
    // testability + single-source-of-truth with the sidebar wiring.
    import '../scripts/showcase.client.ts';
    import '../scripts/preview.client.ts';
    import '../scripts/terminal.client.ts';
    import '../scripts/showcase-spy.client.ts';
  </script>
</BaseLayout>

<style is:global>
  @keyframes hero-caret {
    0%,
    60% {
      opacity: 1;
    }
    61%,
    100% {
      opacity: 0;
    }
  }

  .surfaces {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .surfaces__card {
    padding: 20px;
    background: var(--background-secondary);
    border: 1px solid var(--border-strong);
  }
  .surfaces__kicker {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--foreground-muted);
  }
  .surfaces__title {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--foreground-primary);
  }
  .surfaces__lede {
    margin: 0 0 12px;
    color: var(--foreground-secondary);
    font-size: 15px;
    line-height: 1.5;
  }
  .surfaces__code {
    margin: 0;
    padding: 12px 14px;
    background: var(--editor-background);
    color: var(--foreground-tertiary);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.55;
    overflow-x: auto;
  }

  .foundations-links {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
  }
  .foundations-links a {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    background: var(--background-secondary);
    border: 1px solid var(--border-strong);
    color: var(--foreground-primary);
    text-decoration: none;
    transition:
      border-color var(--dur-fast) var(--ease-snap),
      background-color var(--dur-fast) var(--ease-snap);
  }
  .foundations-links a:hover {
    border-color: var(--cta-background);
    background: var(--background-tertiary);
  }
  .foundations-links strong {
    font-size: 16px;
  }
  .foundations-links span {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--foreground-muted);
  }
</style>
