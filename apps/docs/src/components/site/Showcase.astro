---
import { icons } from '@freecodecamp/uikit-icons';

export interface Props {
  id: string;
  title: string;
  slug: string;
  description?: string;
  previewStacked?: boolean;
  previewPlain?: boolean;
  /** Path under packages/uikit/src/ — used to build the source link. */
  source?: string;
}

const {
  id,
  title,
  slug,
  description,
  previewStacked = false,
  previewPlain = false,
  source
} = Astro.props;

const previewClass = [
  'showcase__preview',
  previewStacked ? 'showcase__preview--stacked' : '',
  previewPlain ? 'showcase__preview--plain' : ''
]
  .filter(Boolean)
  .join(' ');

const sourceHref = source
  ? `https://github.com/freeCodeCamp/ui/blob/main/packages/uikit/src/${source}`
  : null;
---

<section class='section' id={id}>
  <p class='section__eyebrow'>&lt;{slug} /&gt;</p>
  <h3 class='section__title'>{title}</h3>
  {description && <p class='section__lede'>{description}</p>}

  <div class='showcase' data-showcase data-source={source ?? ''}>
    <header class='showcase__head'>
      <p class='showcase__head-title'>{title}</p>
      <p class='showcase__head-meta'>preview</p>
      {
        sourceHref && (
          <a
            class='showcase__source'
            href={sourceHref}
            target='_blank'
            rel='noreferrer noopener'
          >
            <span>source</span>
            <svg
              width='13'
              height='13'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              stroke-linecap='round'
              stroke-linejoin='round'
              data-icon='external-link'
              aria-hidden='true'
              set:html={icons['external-link']}
            />
          </a>
        )
      }
    </header>

    <div class={previewClass}>
      <slot name='preview' />
    </div>

    <div class='showcase__tabs' role='tablist' aria-label={`${title} code`}>
      <button
        class='showcase__tab is-active'
        role='tab'
        aria-selected='true'
        data-tab='react'>React</button
      >
      <button
        class='showcase__tab'
        role='tab'
        aria-selected='false'
        data-tab='html'>HTML</button
      >
      <button
        class='showcase__tab'
        role='tab'
        aria-selected='false'
        data-tab='tailwind'>Tailwind</button
      >

      <div class='showcase__menu' data-copy-menu>
        <button
          class='showcase__copy'
          type='button'
          data-copy
          aria-haspopup='menu'
          aria-expanded='false'
          aria-label='Copy code to clipboard'
        >
          <svg
            width='13'
            height='13'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            data-icon='copy'
            aria-hidden='true'
            set:html={icons.copy}
          />
          <span data-copy-label>Copy</span>
        </button>
        <ul class='showcase__menu-list' role='menu' hidden>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='react'
              >Copy React JSX</button
            >
          </li>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='html'
              >Copy HTML</button
            >
          </li>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='tailwind'
              >Copy Tailwind</button
            >
          </li>
        </ul>
      </div>
    </div>

    <div class='showcase__code'>
      <div class='showcase__panel is-active' role='tabpanel' data-panel='react'>
        <slot name='react' />
      </div>
      <div class='showcase__panel' role='tabpanel' data-panel='html'>
        <slot name='html'><slot name='vanilla' /></slot>
      </div>
      <div class='showcase__panel' role='tabpanel' data-panel='tailwind'>
        <slot name='tailwind'>
          <pre
            class='placeholder'><code>{/* Tailwind snippet coming soon */}</code></pre>
        </slot>
      </div>
    </div>
  </div>
</section>
