---
// Sticky header. SSR-only AppHeader + AppBreadcrumb (returns null at `/`).
// Inline theme-swap + open-search scripts live alongside so Astro doesn't hoist them.
import { AppHeader as AppHeaderCmp } from './AppHeader.tsx';
import { AppBreadcrumb } from './AppBreadcrumb.tsx';

const pathname = Astro.url.pathname;
---

<AppHeaderCmp pathname={pathname} />
<AppBreadcrumb pathname={pathname} />

<script is:inline>
  (function () {
    const btn = document.querySelector('[data-theme-swap]');
    if (btn) {
      const darkIcon = btn.querySelector('[data-icon-dark]');
      const lightIcon = btn.querySelector('[data-icon-light]');
      const sync = () => {
        const light =
          document.documentElement.classList.contains('light-palette');
        if (darkIcon) darkIcon.style.display = light ? 'none' : '';
        if (lightIcon) lightIcon.style.display = light ? '' : 'none';
      };
      sync();
      btn.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.classList.contains('light-palette')
          ? 'dark'
          : 'light';
        root.classList.remove('dark-palette', 'light-palette');
        root.classList.add(next + '-palette');
        try {
          localStorage.setItem('fcc-palette', next);
        } catch {}
        sync();
      });
    }

    const searchBtn = document.querySelector('[data-open-search]');
    if (searchBtn) {
      const openSearch = () =>
        document.dispatchEvent(new CustomEvent('fcc:open-search'));
      searchBtn.addEventListener('click', openSearch);
      document.addEventListener('keydown', e => {
        if (
          e.key === '/' &&
          !/^(INPUT|TEXTAREA)$/.test(document.activeElement?.tagName || '')
        ) {
          e.preventDefault();
          openSearch();
        }
      });
    }

    // Mobile nav drawer: every open/close path flips body[data-nav-open]; CSS owns animation.
    const wireDrawer = () => {
      const navBtn = document.querySelector('[data-nav-toggle]');
      const backdrop = document.querySelector('[data-nav-backdrop]');
      const sidebar = document.getElementById('app-sidebar');
      if (navBtn && sidebar) {
        const hamburgerIcon = navBtn.querySelector("[data-icon='hamburger']");
        const closeIcon = navBtn.querySelector("[data-icon='close']");
        const setOpen = open => {
          document.body.toggleAttribute('data-nav-open', open);
          navBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
          navBtn.setAttribute(
            'aria-label',
            open ? 'Close navigation' : 'Open navigation'
          );
          if (hamburgerIcon) hamburgerIcon.style.display = open ? 'none' : '';
          if (closeIcon) closeIcon.style.display = open ? '' : 'none';
        };
        // Restore focus to the hamburger on close so keyboard/AT users land on a meaningful anchor.
        const close = () => {
          setOpen(false);
          navBtn.focus();
        };
        navBtn.addEventListener('click', () =>
          setOpen(navBtn.getAttribute('aria-expanded') !== 'true')
        );
        backdrop?.addEventListener('click', close);
        document.addEventListener('keydown', e => {
          if (
            e.key === 'Escape' &&
            document.body.hasAttribute('data-nav-open')
          ) {
            close();
          }
        });
        // Link-click dismisses without refocusing — destination page owns post-nav focus.
        sidebar.addEventListener('click', e => {
          const target = e.target;
          if (target instanceof HTMLElement && target.closest('a[href]')) {
            setOpen(false);
          }
        });
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wireDrawer);
    } else {
      wireDrawer();
    }
  })();
</script>
