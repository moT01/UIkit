---
// Sticky site header — dogfoods @freecodecamp/uikit's <Navbar>.
// Chrome composition lives in AppHeader.tsx; this wrapper renders it
// SSR-only and keeps the inline theme-swap + open-search scripts as
// siblings so Astro does not hoist them.
//
// Wave 9 P2.11 (W9-C3) — pass `Astro.url.pathname` so the header can
// stamp `aria-current="page"` on the matching primary link. The
// match policy lives in AppHeader.tsx and is locked by AppHeader.test.tsx.
import { AppHeader } from './AppHeader.tsx';

const pathname = Astro.url.pathname;
---

<AppHeader pathname={pathname} />

<script is:inline>
  (function () {
    const btn = document.querySelector('[data-theme-swap]');
    if (btn) {
      const darkIcon = btn.querySelector('[data-icon-dark]');
      const lightIcon = btn.querySelector('[data-icon-light]');
      const sync = () => {
        const light =
          document.documentElement.classList.contains('light-palette');
        if (darkIcon) darkIcon.style.display = light ? 'none' : '';
        if (lightIcon) lightIcon.style.display = light ? '' : 'none';
      };
      sync();
      btn.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.classList.contains('light-palette')
          ? 'dark'
          : 'light';
        root.classList.remove('dark-palette', 'light-palette');
        root.classList.add(next + '-palette');
        try {
          localStorage.setItem('fcc-palette', next);
        } catch {}
        sync();
      });
    }

    const searchBtn = document.querySelector('[data-open-search]');
    if (searchBtn) {
      const openSearch = () =>
        document.dispatchEvent(new CustomEvent('fcc:open-search'));
      searchBtn.addEventListener('click', openSearch);
      document.addEventListener('keydown', e => {
        if (
          e.key === '/' &&
          !/^(INPUT|TEXTAREA)$/.test(document.activeElement?.tagName || '')
        ) {
          e.preventDefault();
          openSearch();
        }
      });
    }

    // Mobile nav drawer wiring. Hamburger, backdrop, ESC, and
    // closing-on-link-click all flip the same body attribute; CSS
    // owns the slide animation. Defer binding until DOM is fully
    // parsed — the sidebar appears later in the document.
    const wireDrawer = () => {
      const navBtn = document.querySelector('[data-nav-toggle]');
      const backdrop = document.querySelector('[data-nav-backdrop]');
      const sidebar = document.getElementById('app-sidebar');
      if (navBtn && sidebar) {
        const hamburgerIcon = navBtn.querySelector("[data-icon='hamburger']");
        const closeIcon = navBtn.querySelector("[data-icon='close']");
        const setOpen = open => {
          document.body.toggleAttribute('data-nav-open', open);
          navBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
          navBtn.setAttribute(
            'aria-label',
            open ? 'Close navigation' : 'Open navigation'
          );
          if (hamburgerIcon) hamburgerIcon.style.display = open ? 'none' : '';
          if (closeIcon) closeIcon.style.display = open ? '' : 'none';
        };
        // Wave 8 P5 (W8-7) — close-path focus restoration. Every
        // close path (ESC, backdrop tap, link click) returns focus
        // to the hamburger so keyboard + assistive-tech users land
        // back at a meaningful anchor instead of <body>.
        const close = () => {
          setOpen(false);
          navBtn.focus();
        };
        navBtn.addEventListener('click', () =>
          setOpen(navBtn.getAttribute('aria-expanded') !== 'true')
        );
        backdrop?.addEventListener('click', close);
        document.addEventListener('keydown', e => {
          if (
            e.key === 'Escape' &&
            document.body.hasAttribute('data-nav-open')
          ) {
            close();
          }
        });
        // Clicking a nav link dismisses the drawer so the main surface
        // gets focus after route change. We intentionally don't refocus
        // the hamburger here — the destination page's focus management
        // owns the post-navigation focus surface.
        sidebar.addEventListener('click', e => {
          const target = e.target;
          if (target instanceof HTMLElement && target.closest('a[href]')) {
            setOpen(false);
          }
        });
      }
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wireDrawer);
    } else {
      wireDrawer();
    }
  })();
</script>
