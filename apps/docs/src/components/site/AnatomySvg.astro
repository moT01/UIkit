---
// Numbered anatomy diagram. Pass an SVG path + a legend array.
// Use on per-component MDX pages to annotate structural parts.
export interface Legend {
  n: number;
  label: string;
}
export interface Props {
  src: string;
  alt?: string;
  legend: Legend[];
}
const { src, alt = 'Component anatomy diagram', legend } = Astro.props;
---

<figure class='anatomy'>
  <div class='anatomy__frame'>
    <img src={src} alt={alt} loading='lazy' />
  </div>
  <ol class='anatomy__legend' role='list'>
    {
      legend.map(item => (
        <li>
          <span class='anatomy__n'>{item.n}</span>
          {item.label}
        </li>
      ))
    }
  </ol>
</figure>

<style>
  .anatomy {
    margin: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18rem;
    gap: var(--space-4, 1.5rem);
    align-items: start;
  }
  .anatomy__frame {
    border: 2px solid var(--background-tertiary, #2a2a40);
    padding: var(--space-4, 1.5rem);
    background: var(--background-secondary, #1b1b32);
  }
  .anatomy__frame img {
    display: block;
    max-width: 100%;
    height: auto;
  }
  .anatomy__legend {
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--foreground-secondary, #dfdfe2);
  }
  .anatomy__legend li {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.25rem 0;
  }
  .anatomy__n {
    display: inline-block;
    min-width: 1.75rem;
    padding: 0 0.25rem;
    border: 1px solid var(--cta-background, #f1be32);
    color: var(--cta-background, #f1be32);
    text-align: center;
  }
  @media (max-width: 720px) {
    .anatomy {
      grid-template-columns: 1fr;
    }
  }
</style>
