---
// Pagefind-backed site search. Renders a modal dialog triggered by the
// AppHeader's "/" shortcut (or anything that dispatches
// `fcc:open-search`). Pagefind's drop-in UI owns the input + result
// list; we just load its assets and wrap the mount point in our
// dialog chrome so the search surface looks like the rest of the kit.
//
// The /_pagefind/ folder is generated by the post-build step
// (`astro build && pagefind --site dist ...`). During `astro dev` the
// folder does not exist — search is a production-only feature, which
// matches Pagefind's static-by-design model.
---

<dialog class='search-dialog' data-search-dialog aria-label='Search UIKit'>
  <form
    method='dialog'
    class='search-dialog__close-form'
    aria-label='Dismiss search'
  >
    <button
      class='search-dialog__close'
      type='submit'
      value='close'
      aria-label='Close search'>×</button
    >
  </form>
  <div id='pagefind-search' class='search-dialog__mount'></div>
</dialog>

<link rel='stylesheet' href='/_pagefind/pagefind-ui.css' />
<script is:inline src='/_pagefind/pagefind-ui.js' defer></script>

<script is:inline>
  (function () {
    const dialog = document.querySelector('[data-search-dialog]');
    if (!dialog) return;

    let mounted = false;

    function openSearch() {
      if (!mounted) {
        const mount = document.getElementById('pagefind-search');
        const Ctor = window.PagefindUI;
        if (Ctor && mount) {
          new Ctor({
            element: '#pagefind-search',
            showImages: false,
            showSubResults: true,
            resetStyles: false
          });
        } else if (mount) {
          // In `astro dev` the /_pagefind/ folder does not exist; degrade
          // to an explanatory note so the surface never looks broken.
          mount.innerHTML =
            '<p class="search-dialog__note">Search indexes live on the built site. Run <code>pnpm --filter @freecodecamp/uikit-docs build</code> to generate the Pagefind bundle locally.</p>';
        }
        mounted = true;
      }
      if (!dialog.open) dialog.showModal();
      const input = dialog.querySelector('input[type="search"]');
      if (input) input.focus();
    }

    document.addEventListener('fcc:open-search', openSearch);

    // Close on backdrop click — native <dialog> does not do this for us.
    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>

<style is:global>
  .search-dialog {
    padding: 0;
    border: 1px solid var(--border-strong);
    background: var(--background-secondary);
    color: var(--foreground-primary);
    max-width: 680px;
    width: min(90vw, 680px);
    max-height: 80vh;
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
  }
  .search-dialog__close-form {
    position: absolute;
    right: 8px;
    top: 6px;
    margin: 0;
  }
  .search-dialog__close {
    background: transparent;
    border: 0;
    font-size: 22px;
    line-height: 1;
    color: var(--foreground-muted);
    cursor: pointer;
  }
  .search-dialog__close:hover {
    color: var(--foreground-primary);
  }
  .search-dialog__mount {
    padding: 20px 24px 24px;
  }
  .search-dialog__note {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--foreground-muted);
    margin: 24px 0;
  }
</style>
