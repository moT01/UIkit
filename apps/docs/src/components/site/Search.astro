---

---

<dialog class='search-dialog' data-search-dialog aria-label='Search UIKit'>
  <form
    method='dialog'
    class='search-dialog__close-form'
    aria-label='Dismiss search'
  >
    <button
      class='search-dialog__close'
      type='submit'
      value='close'
      aria-label='Close search'>×</button
    >
  </form>
  <div class='search-dialog__mount'>
    <input
      class='search-dialog__input'
      type='search'
      data-search-input
      placeholder='Search components, guides, foundations'
      aria-label='Search'
      autocomplete='off'
      spellcheck='false'
    />
    <ul class='search-dialog__results' data-search-results role='list'></ul>
  </div>
</dialog>

<script>
  import '../../scripts/search.client.ts';
</script>

<script is:inline>
  (function () {
    const dialog = document.querySelector('[data-search-dialog]');
    if (!dialog) return;

    function openSearch() {
      if (!dialog.open) dialog.showModal();
      const input = dialog.querySelector('[data-search-input]');
      if (input) input.focus();
    }

    document.addEventListener('fcc:open-search', openSearch);

    // Close on backdrop click — native <dialog> does not do this.
    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>

<style is:global>
  .search-dialog {
    padding: 0;
    border: 1px solid var(--border-strong);
    background: var(--background-secondary);
    color: var(--foreground-primary);
    max-width: 680px;
    width: min(90vw, 680px);
    max-height: 80vh;
  }
  .search-dialog::backdrop {
    background: rgb(0 0 0 / 0.55);
  }
  .search-dialog__close-form {
    position: absolute;
    right: 8px;
    top: 6px;
    margin: 0;
  }
  .search-dialog__close {
    background: transparent;
    border: 0;
    font-size: 22px;
    line-height: 1;
    color: var(--foreground-muted);
    cursor: pointer;
  }
  .search-dialog__close:hover {
    color: var(--foreground-primary);
  }
  .search-dialog__mount {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .search-dialog__input {
    width: 100%;
    padding: 10px 12px;
    background: var(--background-primary);
    border: 1px solid var(--foreground-quaternary);
    color: var(--foreground-primary);
    font-family: var(--font-sans);
    font-size: 14px;
  }
  .search-dialog__input:focus-visible {
    outline: 2px solid var(--cta-background);
    outline-offset: 2px;
  }
  .search-dialog__results {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    max-height: 60vh;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .search-results__item {
    margin: 0;
  }
  .search-results__link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    color: var(--foreground-primary);
    text-decoration: none;
    border: 1px solid transparent;
  }
  .search-results__link:hover,
  .search-results__link:focus-visible {
    border-color: var(--foreground-quaternary);
    background: var(--background-primary);
  }
  .search-results__title {
    font-weight: 600;
    font-size: 14px;
  }
  .search-results__summary {
    font-size: 12px;
    color: var(--foreground-muted);
  }
  .search-results__hint,
  .search-results__error {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--foreground-muted);
    padding: 8px 10px;
  }
  .search-results__error {
    color: var(--danger-foreground);
  }
  .search-results__score {
    color: var(--foreground-muted);
    font-size: 11px;
  }
</style>
