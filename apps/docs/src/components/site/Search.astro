---
// Pagefind-backed site search. Renders a modal dialog triggered by the
// AppHeader's "/" shortcut (or anything that dispatches
// `fcc:open-search`). Migrated to the **Component UI** in Pagefind
// 1.5+ — a set of `<pagefind-*>` web components that self-register
// when the script loads. The old `new PagefindUI()` constructor is
// gone; configuration now lives in `<pagefind-config>` attributes.
//
// The /_pagefind/ folder is generated by the post-build step
// (`astro build && pagefind --site dist ...`). During `astro dev` the
// folder does not exist — search is a production-only feature, which
// matches Pagefind's static-by-design model.
---

<dialog class='search-dialog' data-search-dialog aria-label='Search UIKit'>
  <form
    method='dialog'
    class='search-dialog__close-form'
    aria-label='Dismiss search'
  >
    <button
      class='search-dialog__close'
      type='submit'
      value='close'
      aria-label='Close search'>×</button
    >
  </form>
  <div class='search-dialog__mount'>
    <pagefind-config show-images='false' show-sub-results='true'
    ></pagefind-config>
    <pagefind-input
      placeholder='Search components, guides, foundations'
      auto-focus='true'></pagefind-input>
    <pagefind-summary></pagefind-summary>
    <pagefind-results></pagefind-results>
    <p class='search-dialog__note' data-search-dev-note hidden>
      Search indexes live on the built site. Run <code
        >pnpm --filter @freecodecamp/uikit-docs build</code
      > to generate the Pagefind bundle locally.
    </p>
  </div>
</dialog>

<link rel='stylesheet' href='/_pagefind/pagefind-component-ui.css' />
<script is:inline src='/_pagefind/pagefind-component-ui.js' defer></script>

<script is:inline>
  (function () {
    const dialog = document.querySelector('[data-search-dialog]');
    if (!dialog) return;

    function openSearch() {
      if (!dialog.open) dialog.showModal();
      // The Pagefind component auto-focuses its internal input once
      // the custom element is upgraded, but a belt-and-braces focus
      // here catches the dev-mode fallback too.
      const input = dialog.querySelector('pagefind-input input, input');
      if (input) input.focus();

      // Dev-mode: if the Component UI script failed to register the
      // element (no /_pagefind/ folder), surface a note instead of an
      // empty dialog.
      const probe = dialog.querySelector('pagefind-input');
      if (probe && !probe.shadowRoot) {
        const note = dialog.querySelector('[data-search-dev-note]');
        if (note) note.hidden = false;
      }
    }

    document.addEventListener('fcc:open-search', openSearch);

    // Close on backdrop click — native <dialog> does not do this.
    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) dialog.close();
    });
  })();
</script>

<style is:global>
  .search-dialog {
    padding: 0;
    border: 1px solid var(--border-strong);
    background: var(--background-secondary);
    color: var(--foreground-primary);
    max-width: 680px;
    width: min(90vw, 680px);
    max-height: 80vh;
  }
  .search-dialog::backdrop {
    background: rgb(0 0 0 / 0.55);
  }
  .search-dialog__close-form {
    position: absolute;
    right: 8px;
    top: 6px;
    margin: 0;
  }
  .search-dialog__close {
    background: transparent;
    border: 0;
    font-size: 22px;
    line-height: 1;
    color: var(--foreground-muted);
    cursor: pointer;
  }
  .search-dialog__close:hover {
    color: var(--foreground-primary);
  }
  .search-dialog__mount {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .search-dialog__note {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--foreground-muted);
    margin: 8px 0 0;
  }
  /* Nudge the Pagefind web components to inherit our palette. */
  pagefind-input,
  pagefind-summary,
  pagefind-results {
    --pagefind-ui-primary: var(--cta-background);
    --pagefind-ui-background: var(--background-primary);
    --pagefind-ui-text: var(--foreground-primary);
    --pagefind-ui-border: var(--foreground-quaternary);
    --pagefind-ui-font: var(--font-sans);
  }
</style>
