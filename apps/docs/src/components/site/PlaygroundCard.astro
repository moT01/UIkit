---
// Wave 6 / Wave 7 — PlaygroundCard. Single per-component surface on `/`:
// eyebrow → big title → lead → grid-bordered preview → REACT|HTML|
// TAILWIND tabs with copy menu → optional ANATOMY <details>. The
// data-attribute contract drives showcase.client.ts (tab switching,
// copy-as menu, scroll-spy). Wave 7 P0 retired the legacy per-component
// route; `source` is required so the View source link always renders.
import { icons } from '@freecodecamp/uikit-icons';

export interface Props {
  /** Anchor slug; must match a knownComponentSlug entry. */
  id: string;
  /** Big title — "Button". */
  title: string;
  /** Eyebrow source — renders as <COMPONENT />. */
  slug: string;
  description?: string;
  /** Path under packages/uikit/src/ for the source link. Required. */
  source: string;
  status?: 'stable' | 'beta' | 'planned';
  since?: string;
  /** CSS custom-property names this component reads, e.g. ['--color-primary']. */
  tokens?: string[];
  /** WAI-ARIA APG URL or pattern name. */
  a11yPattern?: string;
  previewStacked?: boolean;
  previewPlain?: boolean;
  /** When true, the ANATOMY <details> block renders open. Wave 7 P3 —
   * the FIRST card on `/` (typically Button) sets this so the user
   * sees the anatomy block expanded by default; rest stay closed. */
  defaultOpen?: boolean;
}

const {
  id,
  title,
  slug,
  description,
  source,
  status,
  since,
  tokens,
  a11yPattern,
  previewStacked = false,
  previewPlain = false,
  defaultOpen = false
} = Astro.props;

const previewClass = [
  'showcase__preview',
  previewStacked ? 'showcase__preview--stacked' : '',
  previewPlain ? 'showcase__preview--plain' : ''
]
  .filter(Boolean)
  .join(' ');

const sourceHref = `https://github.com/freeCodeCamp/ui/blob/main/packages/uikit/src/${source}`;

const hasAnatomy = Boolean(
  status || since || (tokens && tokens.length) || a11yPattern
);
---

<section class='section' id={id}>
  <p class='section__eyebrow'>&lt;{slug} /&gt;</p>
  <h3 class='section__title'>{title}</h3>
  {description && <p class='section__lede'>{description}</p>}

  <div class='showcase' data-showcase data-source={source ?? ''}>
    <header class='showcase__head'>
      <p class='showcase__head-title'>{title}</p>
      <p class='showcase__head-meta'>preview</p>
      <a
        class='showcase__source'
        href={sourceHref}
        target='_blank'
        rel='noreferrer noopener'
      >
        <span>source</span>
        <svg
          width='13'
          height='13'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          data-icon='external-link'
          aria-hidden='true'
          set:html={icons['external-link']}
        />
      </a>
    </header>

    <div class={previewClass}>
      <slot name='preview' />
    </div>

    <div class='showcase__tabs' role='tablist' aria-label={`${title} code`}>
      <button
        class='showcase__tab is-active'
        role='tab'
        aria-selected='true'
        data-tab='react'>React</button
      >
      <button
        class='showcase__tab'
        role='tab'
        aria-selected='false'
        data-tab='html'>HTML</button
      >
      <button
        class='showcase__tab'
        role='tab'
        aria-selected='false'
        data-tab='tailwind'>Tailwind</button
      >

      <div class='showcase__menu' data-copy-menu>
        <button
          class='showcase__copy'
          type='button'
          data-copy
          aria-haspopup='menu'
          aria-expanded='false'
          aria-label='Copy code to clipboard'
        >
          <svg
            width='13'
            height='13'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            data-icon='copy'
            aria-hidden='true'
            set:html={icons.copy}
          />
          <span data-copy-label>Copy</span>
        </button>
        <ul class='showcase__menu-list' role='menu' hidden>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='react'
              >Copy React JSX</button
            >
          </li>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='html'
              >Copy HTML</button
            >
          </li>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='tailwind'
              >Copy Tailwind</button
            >
          </li>
        </ul>
      </div>
    </div>

    <div class='showcase__code'>
      <div class='showcase__panel is-active' role='tabpanel' data-panel='react'>
        <slot name='react' />
      </div>
      <div class='showcase__panel' role='tabpanel' data-panel='html'>
        <slot name='html'><slot name='vanilla' /></slot>
      </div>
      <div class='showcase__panel' role='tabpanel' data-panel='tailwind'>
        <slot name='tailwind'>
          <pre
            class='placeholder'><code>{`// This component is BEM-first; the Tailwind tab is populated
// per-showcase. Copy the HTML tab and swap its class list for
// Tailwind utilities, or pull the preset from
// @freecodecamp/uikit-tailwind.`}</code></pre>
        </slot>
      </div>
    </div>

    {
      hasAnatomy && (
        <details class='showcase__anatomy' open={defaultOpen || undefined}>
          <summary>Anatomy</summary>
          <dl class='showcase__anatomy-list'>
            {status && (
              <>
                <dt>Status</dt>
                <dd>{status}</dd>
              </>
            )}
            {since && (
              <>
                <dt>Since</dt>
                <dd>{since}</dd>
              </>
            )}
            {tokens && tokens.length > 0 && (
              <>
                <dt>Tokens</dt>
                <dd>
                  <ul class='showcase__token-list'>
                    {tokens.map(token => (
                      <li>
                        <code>{token}</code>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )}
            {a11yPattern && (
              <>
                <dt>A11y pattern</dt>
                <dd>
                  {a11yPattern.startsWith('http') ? (
                    <a
                      href={a11yPattern}
                      target='_blank'
                      rel='noreferrer noopener'
                    >
                      {a11yPattern}
                    </a>
                  ) : (
                    a11yPattern
                  )}
                </dd>
              </>
            )}
          </dl>
        </details>
      )
    }
  </div>
</section>
