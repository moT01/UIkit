---
// Per-component card on `/`: eyebrow → title → lede → preview → REACT/HTML tabs → optional ANATOMY.
// data-attributes drive showcase.client.ts (tabs, copy-as menu, scroll-spy).
import { icons } from '@freecodecamp/uikit-icons';
import propsManifest from '@freecodecamp/uikit/props.json';
import { PropTable } from './PropTable.tsx';

export interface Props {
  /** Anchor slug; must match a knownComponentSlug entry. */
  id: string;
  /** Big title — "Button". */
  title: string;
  /** Eyebrow source — renders as <COMPONENT />. */
  slug: string;
  description?: string;
  /** Path under packages/uikit/src/ for the source link. Required. */
  source: string;
  status?: 'stable' | 'beta' | 'planned';
  since?: string;
  /** CSS custom-property names this component reads, e.g. ['--color-primary']. */
  tokens?: string[];
  /** WAI-ARIA APG URL or pattern name. */
  a11yPattern?: string;
  previewStacked?: boolean;
  previewPlain?: boolean;
  /** Render ANATOMY open. First card on `/` sets this so anatomy is visible by default. */
  defaultOpen?: boolean;
}

const {
  id,
  title,
  slug,
  description,
  source,
  status,
  since,
  tokens,
  a11yPattern,
  previewStacked = false,
  previewPlain = false,
  defaultOpen = false
} = Astro.props;

const previewClass = [
  'showcase__preview',
  previewStacked ? 'showcase__preview--stacked' : '',
  previewPlain ? 'showcase__preview--plain' : ''
]
  .filter(Boolean)
  .join(' ');

const sourceHref = `https://github.com/freeCodeCamp/ui/blob/main/packages/uikit/src/${source}`;

type PropEntryProp = {
  type: string;
  required: boolean;
  description: string;
  defaultValue: string | null;
};
type PropEntry = {
  displayName: string;
  description: string;
  props: Record<string, PropEntryProp>;
  _extractionFailed?: boolean;
};
type PropsManifest = Record<string, PropEntry | undefined> & {
  $schemaVersion?: string;
};
const manifest = propsManifest as PropsManifest;
const propsEntry = manifest[slug];
const hasPropTable = Boolean(
  propsEntry &&
  !propsEntry._extractionFailed &&
  Object.keys(propsEntry.props).length > 0
);
const hasExtractionFallback = Boolean(propsEntry?._extractionFailed);

const hasAnatomy = Boolean(
  status ||
  since ||
  (tokens && tokens.length) ||
  a11yPattern ||
  hasPropTable ||
  hasExtractionFallback
);
---

<section class='section' id={id}>
  <p class='section__eyebrow'>&lt;{slug} /&gt;</p>
  <h3 class='section__title'>{title}</h3>
  {description && <p class='section__lede'>{description}</p>}

  <div class='showcase' data-showcase data-source={source ?? ''}>
    <header class='showcase__head'>
      <p class='showcase__head-title'>{title}</p>
      <p class='showcase__head-meta'>preview</p>
      <a
        class='showcase__source'
        href={sourceHref}
        target='_blank'
        rel='noreferrer noopener'
      >
        <span>source</span>
        <svg
          width='13'
          height='13'
          viewBox='0 0 24 24'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          stroke-linecap='round'
          stroke-linejoin='round'
          data-icon='external-link'
          aria-hidden='true'
          set:html={icons['external-link']}
        />
      </a>
    </header>

    <div class={previewClass}>
      <slot name='preview' />
    </div>

    <div class='showcase__tabs' role='tablist' aria-label={`${title} code`}>
      <button
        class='showcase__tab is-active'
        type='button'
        role='tab'
        aria-selected='true'
        data-tab='react'>React</button
      >
      <button
        class='showcase__tab'
        type='button'
        role='tab'
        aria-selected='false'
        data-tab='html'>HTML</button
      >

      <div class='showcase__menu' data-copy-menu>
        <button
          class='showcase__copy'
          type='button'
          data-copy
          aria-haspopup='menu'
          aria-expanded='false'
          aria-label='Copy code to clipboard'
        >
          <svg
            width='13'
            height='13'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            data-icon='copy'
            aria-hidden='true'
            set:html={icons.copy}
          />
          <span data-copy-label>Copy</span>
        </button>
        <ul class='showcase__menu-list' role='menu' hidden>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='react'
              >Copy React JSX</button
            >
          </li>
          <li role='none'>
            <button role='menuitem' type='button' data-copy-as='html'
              >Copy HTML</button
            >
          </li>
        </ul>
      </div>
    </div>

    <div class='showcase__code'>
      <div class='showcase__panel is-active' role='tabpanel' data-panel='react'>
        <slot name='react' />
      </div>
      <div class='showcase__panel' role='tabpanel' data-panel='html'>
        <slot name='html'><slot name='vanilla' /></slot>
      </div>
    </div>

    {
      hasAnatomy && (
        <details class='showcase__anatomy' open={defaultOpen || undefined}>
          <summary>Anatomy</summary>
          <dl class='showcase__anatomy-list'>
            {status && (
              <>
                <dt>Status</dt>
                <dd>{status}</dd>
              </>
            )}
            {since && (
              <>
                <dt>Since</dt>
                <dd>{since}</dd>
              </>
            )}
            {tokens && tokens.length > 0 && (
              <>
                <dt>Tokens</dt>
                <dd>
                  <ul class='showcase__token-list'>
                    {tokens.map(token => (
                      <li>
                        <code>{token}</code>
                      </li>
                    ))}
                  </ul>
                </dd>
              </>
            )}
            {a11yPattern && (
              <>
                <dt>A11y pattern</dt>
                <dd>
                  {a11yPattern.startsWith('http') ? (
                    <a
                      href={a11yPattern}
                      target='_blank'
                      rel='noreferrer noopener'
                    >
                      {a11yPattern}
                    </a>
                  ) : (
                    a11yPattern
                  )}
                </dd>
              </>
            )}
            {(hasPropTable || hasExtractionFallback) && propsEntry && (
              <>
                <dt>Props</dt>
                <dd>
                  <PropTable entry={propsEntry} />
                </dd>
              </>
            )}
          </dl>
        </details>
      )
    }
  </div>
</section>
