---
import { getCollection } from 'astro:content';

// RelatedComponents — card row pointing at sibling components.
// Pass the slugs to surface; missing entries are skipped silently so
// that MDX authored ahead of a sibling ship still renders.
export interface Props {
  slugs: string[];
}
const { slugs } = Astro.props;

const collection = await getCollection('components');
const cards = slugs
  .map(slug => collection.find(entry => entry.id === slug))
  .filter((entry): entry is (typeof collection)[number] => Boolean(entry));
---

{
  cards.length > 0 && (
    <aside class='related' aria-label='Related components'>
      <p class='related__label'>Related</p>
      <ul role='list'>
        {cards.map(entry => (
          <li>
            <a href={`/playground#${entry.id}`}>
              <p class='related__eyebrow'>{entry.data.eyebrow}</p>
              <p class='related__title'>{entry.data.title}</p>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .related {
    border-top: 2px solid var(--background-tertiary, #2a2a40);
    padding: var(--space-4, 1.5rem) 0;
  }
  .related__label {
    font-family: var(--font-mono);
    text-transform: lowercase;
    letter-spacing: 0.06em;
    font-size: 0.8125rem;
    color: var(--cta-background, #f1be32);
    margin: 0 0 0.75rem;
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3, 1rem);
  }
  .related a {
    display: block;
    border: 2px solid var(--background-tertiary, #2a2a40);
    padding: var(--space-3, 1rem);
    color: inherit;
    text-decoration: none;
    background: var(--background-secondary, #1b1b32);
    transition: border-color 120ms
      var(--ease-snap, cubic-bezier(0.2, 0.8, 0.2, 1));
  }
  .related a:hover,
  .related a:focus-visible {
    border-color: var(--cta-background, #f1be32);
  }
  .related__eyebrow {
    font-family: var(--font-mono);
    color: var(--cta-background, #f1be32);
    margin: 0 0 0.25rem;
    font-size: 0.8125rem;
  }
  .related__title {
    margin: 0;
    font-weight: 500;
  }
</style>
