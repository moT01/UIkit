---
// Docs sidebar — dogfoods @freecodecamp/uikit's <Sidebar>+<SidebarSection>
// +<SidebarItem>. Active state is route-aware (derived from
// `Astro.url.pathname`), so no client-side script is required.
//
// Wave 4 · 4.6 narrowed rendering to the two scroll-anchored surfaces —
// `/` (the Playground) and `/handbook`. Every other route ships
// without a sidebar rail, trading the 45-item nav for more content
// surface.
//
// At ≤900 px the sidebar becomes an off-canvas drawer; the toggle
// logic lives in `AppHeader.astro`'s inline script (data-nav-toggle
// driving `<body data-nav-open>`). The `id='app-sidebar'` matches
// `aria-controls` on the hamburger.
import { AppSidebar } from './AppSidebar.tsx';
import { nav } from '../../data/nav.ts';

const currentPath = Astro.url.pathname;
const currentHash = Astro.url.hash;
const WITH_SIDEBAR = new Set<string>(['/', '/handbook', '/handbook/']);
const showSidebar = WITH_SIDEBAR.has(currentPath);
---

{
  showSidebar && (
    <>
      <div class='app__sidebar' id='app-sidebar'>
        <AppSidebar
          nav={nav}
          currentPath={currentPath}
          currentHash={currentHash}
        />
      </div>
      <button
        class='app__backdrop'
        type='button'
        aria-hidden='true'
        tabindex='-1'
        data-nav-backdrop
      />
    </>
  )
}
