---
// 8-step visual ruler for the --space-* scale. Each row renders a block
// whose width resolves from the token itself, so bumping the scale in
// tokens.css updates the preview for free.

const steps = [
  { token: '--space-0', label: '0 — zero' },
  { token: '--space-1', label: '4 — hairline gap' },
  { token: '--space-2', label: '8 — inline rhythm' },
  { token: '--space-3', label: '12 — inside control' },
  { token: '--space-4', label: '16 — card padding' },
  { token: '--space-5', label: '24 — block rhythm' },
  { token: '--space-6', label: '32 — section padding' },
  { token: '--space-7', label: '48 — section gap' },
  { token: '--space-8', label: '64 — page rhythm' }
];
---

<ul class='ruler' role='list'>
  {
    steps.map(({ token, label }) => (
      <li class='ruler__row'>
        <p class='ruler__token'>{token}</p>
        <div
          class='ruler__bar'
          style={{ width: `var(${token})` }}
          aria-hidden='true'
        />
        <p class='ruler__label'>{label}</p>
      </li>
    ))
  }
</ul>
