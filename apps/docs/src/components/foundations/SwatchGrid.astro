---
// Swatch grid: each entry renders a colour chip with the live token value
// (CSS custom property) alongside its resolved static hex for reference.
// Clicking the chip copies the `var(--token)` string to the clipboard so
// readers can paste it straight into code.

export interface Swatch {
  token: string;
  hex: string;
  label?: string;
}

export interface Props {
  swatches: Swatch[];
}

const { swatches } = Astro.props;
---

<ul class='foundation-swatches' role='list'>
  {
    swatches.map(({ token, hex, label }) => (
      <li class='foundation-swatch'>
        <button
          class='foundation-swatch__chip'
          type='button'
          data-copy-token={`var(${token})`}
          style={{ background: `var(${token})` }}
          aria-label={`Copy var(${token})`}
        />
        <div class='foundation-swatch__body'>
          <p class='foundation-swatch__token'>{token}</p>
          <p class='foundation-swatch__hex'>{hex}</p>
          {label && <p class='foundation-swatch__label'>{label}</p>}
        </div>
      </li>
    ))
  }
</ul>

<script>
  document
    .querySelectorAll<HTMLButtonElement>('[data-copy-token]')
    .forEach(btn => {
      btn.addEventListener('click', async () => {
        const value = btn.dataset.copyToken ?? '';
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
          btn.classList.add('is-copied');
          window.setTimeout(() => btn.classList.remove('is-copied'), 1200);
        } catch {
          /* noop — clipboard unavailable */
        }
      });
    });
</script>
