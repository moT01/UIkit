---
// Side-by-side palette preview. Two tiles (dark + light) each
// contain the same miniature component assortment so the reader can
// see, at a glance, how the UIKit re-themes when `.light-palette`
// is applied. Scoped: each tile is a self-contained palette root
// that doesn't rely on the page's global palette class.

interface Demo {
  label: string;
  variantClass: string;
}

const demos: Demo[] = [
  { label: 'Dark palette', variantClass: 'dark-palette' },
  { label: 'Light palette', variantClass: 'light-palette' }
];
---

<div class='palette-gallery'>
  {
    demos.map(demo => (
      <article class={`palette-gallery__tile ${demo.variantClass}`}>
        <header class='palette-gallery__tile-header'>
          <span class='palette-gallery__kicker'>{demo.label}</span>
          <code class='palette-gallery__token'>.{demo.variantClass}</code>
        </header>
        <div class='palette-gallery__surface'>
          <p class='palette-gallery__lede'>
            Campfire-friendly copy — tokens flow from{' '}
            <code>--background-primary</code> and{' '}
            <code>--foreground-primary</code> down to every component.
          </p>
          <div class='palette-gallery__row'>
            <button type='button' class='btn btn--cta btn--sm'>
              Primary
            </button>
            <button type='button' class='btn btn--sm'>
              Secondary
            </button>
            <span class='chip chip--stable'>stable</span>
          </div>
          <div class='palette-gallery__row'>
            <span class='palette-gallery__swatch palette-gallery__swatch--bg'>
              bg
            </span>
            <span class='palette-gallery__swatch palette-gallery__swatch--fg'>
              fg
            </span>
            <span class='palette-gallery__swatch palette-gallery__swatch--cta'>
              cta
            </span>
          </div>
        </div>
      </article>
    ))
  }
</div>

<style is:global>
  .palette-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin: 24px 0 8px;
  }
  .palette-gallery__tile {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 18px 20px 22px;
    border: 1px solid var(--foreground-quaternary);
    background: var(--background-primary);
    color: var(--foreground-primary);
    border-radius: 2px;
  }
  .palette-gallery__tile-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    padding-bottom: 8px;
    border-bottom: 1px dashed var(--foreground-quaternary);
  }
  .palette-gallery__kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--foreground-secondary);
  }
  .palette-gallery__token {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--foreground-muted);
  }
  .palette-gallery__lede {
    margin: 0;
    color: var(--foreground-secondary);
    font-size: var(--fs-sm);
    line-height: var(--lh-loose);
  }
  .palette-gallery__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .palette-gallery__swatch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    border: 1px solid var(--foreground-quaternary);
  }
  .palette-gallery__swatch--bg {
    background: var(--background-secondary);
    color: var(--foreground-primary);
  }
  .palette-gallery__swatch--fg {
    background: var(--foreground-primary);
    color: var(--background-primary);
  }
  .palette-gallery__swatch--cta {
    background: var(--cta-background);
    color: var(--cta-foreground);
  }
</style>
