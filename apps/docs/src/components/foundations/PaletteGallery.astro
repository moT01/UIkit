---
// Side-by-side palette preview. Two tiles (dark + light) each
// contain the same miniature component assortment so the reader can
// see, at a glance, how the UIKit re-themes when `.light-palette`
// is applied. Scoped: each tile is a self-contained palette root
// that doesn't rely on the page's global palette class.

interface Demo {
  label: string;
  variantClass: string;
}

const demos: Demo[] = [
  { label: 'Dark palette', variantClass: 'dark-palette' },
  { label: 'Light palette', variantClass: 'light-palette' }
];
---

<div class='palette-gallery'>
  {
    demos.map(demo => (
      <article class={`palette-gallery__tile ${demo.variantClass}`}>
        <header class='palette-gallery__tile-header'>
          <span class='palette-gallery__kicker'>{demo.label}</span>
          <code class='palette-gallery__token'>.{demo.variantClass}</code>
        </header>
        <div class='palette-gallery__surface'>
          <p class='palette-gallery__lede'>
            Campfire-friendly copy — tokens flow from{' '}
            <code>--background-primary</code> and{' '}
            <code>--foreground-primary</code> down to every component.
          </p>
          <div class='palette-gallery__row'>
            <button type='button' class='btn btn--cta btn--sm'>
              Primary
            </button>
            <button type='button' class='btn btn--sm'>
              Secondary
            </button>
            <span class='chip chip--stable'>stable</span>
          </div>
          <div class='palette-gallery__row'>
            <span class='palette-gallery__swatch palette-gallery__swatch--bg'>
              bg
            </span>
            <span class='palette-gallery__swatch palette-gallery__swatch--fg'>
              fg
            </span>
            <span class='palette-gallery__swatch palette-gallery__swatch--cta'>
              cta
            </span>
          </div>
        </div>
      </article>
    ))
  }
</div>
