---
// Wave 6 — long-form prose layout shared by `/guides/*` and any other
// route that wants the table-of-contents + reading shell. The TOC is
// derived from `<h2>` headings on the rendered page (collected by a
// tiny client script that walks the DOM after hydration), so authors
// don't pass anything explicit.
import BaseLayout from './BaseLayout.astro';
import AppHeader from '../components/site/AppHeader.astro';
import AppSidebar from '../components/site/AppSidebar.astro';

export interface Props {
  title: string;
  eyebrow: string;
  summary: string;
}

const { title, eyebrow, summary } = Astro.props;
---

<BaseLayout title={`${title} — freeCodeCamp UIKit`} description={summary}>
  <div class='app app--no-sidebar' id='top'>
    <AppHeader />
    <div class='app__body app__body--single'>
      <AppSidebar />
      <main class='content' tabindex='-1'>
        <div class='content__inner content__inner--prose'>
          <header class='prose-hero'>
            <p class='prose-hero__eyebrow'>{eyebrow}</p>
            <h1 class='prose-hero__title'>{title}</h1>
            <p class='prose-hero__lede'>{summary}</p>
          </header>

          <div class='prose-grid'>
            <aside class='prose-toc' aria-label='On this page' data-prose-toc>
              <p class='prose-toc__label'>On this page</p>
              <nav>
                <ol class='prose-toc__list' data-prose-toc-list></ol>
              </nav>
            </aside>

            <article class='prose'>
              <slot />
            </article>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script>
    // TOC collector — walks `<h2>` elements inside `.prose` and
    // mirrors them into the prose-toc list. Cheap, no library.
    function buildToc() {
      const list = document.querySelector(
        '[data-prose-toc-list]'
      ) as HTMLOListElement | null;
      const article = document.querySelector('.prose') as HTMLElement | null;
      if (!list || !article) return;
      list.innerHTML = '';
      const h2s = article.querySelectorAll<HTMLHeadingElement>('h2[id]');
      if (h2s.length === 0) {
        const wrapper = document.querySelector('[data-prose-toc]');
        if (wrapper) (wrapper as HTMLElement).hidden = true;
        return;
      }
      for (const h2 of h2s) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${h2.id}`;
        a.textContent = h2.textContent ?? '';
        li.appendChild(a);
        list.appendChild(li);
      }
    }
    document.addEventListener('astro:page-load', buildToc);
    buildToc();
  </script>
</BaseLayout>

<style is:global>
  .content__inner--prose {
    max-width: 1080px;
  }
  .prose-hero {
    padding-top: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--background-quaternary);
  }
  .prose-hero__eyebrow {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--foreground-muted);
  }
  .prose-hero__title {
    margin: 0 0 8px;
    font-size: var(--fs-xl);
    line-height: 1.1;
  }
  .prose-hero__lede {
    margin: 0;
    color: var(--foreground-secondary);
    font-size: 18px;
    line-height: 1.5;
    max-width: 70ch;
  }
  .prose-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 32px;
    padding-top: 24px;
  }
  @media (min-width: 1100px) {
    .prose-grid {
      grid-template-columns: minmax(0, 1fr) 240px;
    }
  }
  .prose-toc {
    order: -1;
    border: 1px solid var(--background-quaternary);
    padding: 14px 16px;
    background: var(--background-secondary);
    align-self: start;
    position: sticky;
    top: 80px;
  }
  @media (min-width: 1100px) {
    .prose-toc {
      order: 1;
    }
  }
  .prose-toc__label {
    margin: 0 0 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--foreground-muted);
  }
  .prose-toc__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 6px;
    font-size: 14px;
  }
  .prose-toc__list a {
    color: var(--foreground-secondary);
    text-decoration: none;
    display: block;
    padding: 4px 0;
    border-bottom: 1px solid transparent;
  }
  .prose-toc__list a:hover {
    color: var(--cta-background);
    border-bottom-color: var(--cta-background);
  }

  .prose h2 {
    font-size: var(--fs-lg);
    margin: 32px 0 12px;
    scroll-margin-top: 96px;
  }
  .prose h3 {
    font-size: var(--fs-md);
    margin: 24px 0 8px;
  }
  /* `rehype-autolink-headings` appends a `#` anchor next to each
     heading. Keep it muted and only show on hover/focus so it
     does not compete with prose. */
  .prose :is(h1, h2, h3, h4, h5, h6) .heading-anchor {
    color: var(--foreground-muted);
    text-decoration: none;
    opacity: 0;
    transition: opacity 120ms ease;
    margin-left: 6px;
  }
  .prose :is(h1, h2, h3, h4, h5, h6):hover .heading-anchor,
  .prose :is(h1, h2, h3, h4, h5, h6) .heading-anchor:focus-visible {
    opacity: 1;
  }
  .prose p,
  .prose li {
    color: var(--foreground-secondary);
    line-height: 1.6;
    font-size: 17px;
  }
  .prose pre {
    margin: 16px 0;
    padding: 14px 16px;
    background: var(--editor-background);
    color: var(--foreground-tertiary);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.55;
    overflow-x: auto;
    border: 1px solid var(--border-strong);
  }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.93em;
  }
  .prose :not(pre) > code {
    padding: 1px 6px;
    background: var(--background-tertiary);
    border: 1px solid var(--background-quaternary);
  }
  .prose ul,
  .prose ol {
    padding-left: 22px;
  }
</style>
