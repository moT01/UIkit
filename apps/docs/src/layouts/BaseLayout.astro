---
import Search from '../components/site/Search.astro';

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'The official freeCodeCamp UI kit. Copy-paste components, design tokens, and layout primitives styled in the Command-line Chic language.'
} = Astro.props;
---

<!doctype html>
<html lang='en' dir='ltr' class='dark-palette'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='color-scheme' content='dark light' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:type' content='website' />
    <link rel='icon' href='/favicon.svg' type='image/svg+xml' />
    <link
      rel='preload'
      as='font'
      type='font/woff2'
      href='/fonts/Hack-ZeroSlash-Regular.woff2'
      crossorigin
    />
    <link
      rel='preload'
      as='font'
      type='font/woff'
      href='/fonts/Lato-Regular.woff'
      crossorigin
    />
  </head>
  <body>
    <slot />
    <Search />
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('fcc-palette');
          if (stored === 'light') {
            document.documentElement.classList.remove('dark-palette');
            document.documentElement.classList.add('light-palette');
          }
        } catch {}
      })();
    </script>

    <!--
      Dogfood: the vanilla JS adapter bundle is copied from
      packages/uikit-js/dist into public/uikit/ by scripts/copy-sprite.mjs
      on predev+prebuild. `defer` so the IIFE runs after the DOM is
      parsed, which lets it bind every `data-uikit-*` attribute already
      present in each page body (dialog, pagination, listbox, combobox).
      Plain <script src> instead of a module import because Astro
      tree-shakes side-effect-only imports in layouts.
    -->
    <script src='/uikit/uikit.global.js' defer is:inline></script>

    <style is:global>
      @import '@freecodecamp/uikit-css/tokens.css';
      @import '@freecodecamp/uikit-css/components.css';
      @import '../styles/showcase.css';
    </style>
  </body>
</html>
