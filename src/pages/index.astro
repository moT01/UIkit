---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppHeader from '../components/AppHeader.astro';
import AppSidebar from '../components/AppSidebar.astro';
import Showcase from '../components/Showcase.astro';
import { Code } from 'astro/components';

const tokensPalette = [
  { name: '--background-primary', value: '#0a0a23' },
  { name: '--background-secondary', value: '#1b1b32' },
  { name: '--background-tertiary', value: '#2a2a40' },
  { name: '--background-quaternary', value: '#3b3b4f' },
  { name: '--foreground-primary', value: '#dfdfe2' },
  { name: '--foreground-secondary', value: '#d0d0d5' },
  { name: '--cta-background', value: '#ffbf00' },
  { name: '--highlight-color', value: '#99c9ff' },
  { name: '--success-color', value: '#acd157' },
  { name: '--warning-color', value: '#f1be32' },
  { name: '--danger-color', value: '#ffadad' },
  { name: '--purple-color', value: '#d36eff' }
];

const typeScale = [
  {
    name: 'Display',
    meta: '56 / 1.05 / -0.02em',
    tag: 'h1',
    text: 'Command-line Chic.'
  },
  {
    name: 'Title',
    meta: '42 / 1.15 / -0.01em',
    tag: 'h2',
    text: 'Ship interfaces that feel like home.'
  },
  {
    name: 'Section',
    meta: '32 / 1.2',
    tag: 'h3',
    text: 'Composable primitives.'
  },
  {
    name: 'Subhead',
    meta: '24 / 1.25',
    tag: 'h4',
    text: 'Flat surfaces, square corners.'
  },
  {
    name: 'Lede',
    meta: '20 / 1.5',
    tag: 'p',
    text: 'Type-heavy, shadow-free, accessible by default.'
  },
  {
    name: 'Body',
    meta: '18 / 1.5',
    tag: 'p',
    text: 'Eighteen-pixel minimum. Never compromise the body.'
  },
  {
    name: 'Caption',
    meta: '14 / 1.4 mono',
    tag: 'p',
    text: '404-ROUTE — optimized for 120ch lines of code.'
  }
];

const spacing = [0, 4, 8, 12, 16, 24, 32, 48, 64];
---

<BaseLayout title='fCC UIKit — Components for campers who ship'>
  <div class='app' id='top'>
    <AppHeader />
    <div class='app__body'>
      <AppSidebar />
      <main class='content' tabindex='-1'>
        <div class='content__inner'>
          <!-- ============================================================ -->
          <!-- HERO -->
          <!-- ============================================================ -->
          <section class='hero' id='introduction'>
            <p class='hero__kicker'>fCC UIKit v0.2</p>
            <h1 class='hero__title'>
              Interfaces built in the language <em>campers already speak</em>.
            </h1>
            <p class='hero__lede'>
              A copy-paste component kit for teams shipping learning tools.
              Dark-first, flat surfaces, square corners, and a type scale tuned
              for terminals and textbooks. No framework lock-in — take the React
              file, the vanilla CSS, or both.
            </p>
            <p class='hero__hint'>
              <code
                >@import
                url("https://cdn.freecodecamp.org/uikit/styles.min.css");</code
              > — full setup in the <a class='fcc-link' href='/guides/cdn'
                >CDN guide</a
              >.
            </p>
            <div class='hero__actions'>
              <a class='btn btn--cta' href='/guides'>Read the guides</a>
              <a class='btn' href='#button'>Browse components</a>
              <a
                class='btn btn--ghost'
                href='https://github.com/freeCodeCamp/ui'
                target='_blank'
                rel='noreferrer noopener'>View on GitHub →</a
              >
            </div>
            <dl class='hero__stats'>
              <div class='hero__stat'>
                <p class='hero__stat-value'>21</p>
                <p class='hero__stat-label'>components</p>
              </div>
              <div class='hero__stat'>
                <p class='hero__stat-value'>2</p>
                <p class='hero__stat-label'>flavors — React + Vanilla</p>
              </div>
              <div class='hero__stat'>
                <p class='hero__stat-value'>0kB</p>
                <p class='hero__stat-label'>runtime you don't own</p>
              </div>
              <div class='hero__stat'>
                <p class='hero__stat-value'>AA+</p>
                <p class='hero__stat-label'>contrast, focus, motion</p>
              </div>
            </dl>
          </section>

          <!-- ============================================================ -->
          <!-- TOKENS -->
          <!-- ============================================================ -->
          <section class='section' id='tokens'>
            <p class='section__eyebrow'>01 · design tokens</p>
            <h2 class='section__title'>Tokens</h2>
            <p class='section__lede'>
              The whole kit reads from a small CSS custom-property layer. Swap a
              palette class on <code>&lt;html&gt;</code> and the entire surface changes
              — no component edits, no JavaScript.
            </p>

            <h3 style='font-size:var(--fs-lg);margin:24px 0 12px;'>Palette</h3>
            <div class='token-grid'>
              {
                tokensPalette.map(t => (
                  <div class='swatch'>
                    <div
                      class='swatch__chip'
                      style={`--swatch:${t.value}`}
                      aria-hidden='true'
                    />
                    <div class='swatch__meta'>
                      <span class='swatch__name'>{t.name}</span>
                      <span class='swatch__value'>{t.value}</span>
                    </div>
                  </div>
                ))
              }
            </div>

            <h3 style='font-size:var(--fs-lg);margin:40px 0 12px;'>
              Type scale
            </h3>
            <div>
              {
                typeScale.map(t => (
                  <div class='type-sample'>
                    <p class='type-sample__meta'>
                      {t.name} · {t.meta}
                    </p>
                    <div class='type-sample__body'>
                      {t.tag === 'h1' && <h1 style='margin:0'>{t.text}</h1>}
                      {t.tag === 'h2' && <h2 style='margin:0'>{t.text}</h2>}
                      {t.tag === 'h3' && <h3 style='margin:0'>{t.text}</h3>}
                      {t.tag === 'h4' && <h4 style='margin:0'>{t.text}</h4>}
                      {t.tag === 'p' && <p style='margin:0'>{t.text}</p>}
                    </div>
                  </div>
                ))
              }
            </div>

            <h3 style='font-size:var(--fs-lg);margin:40px 0 12px;'>Spacing</h3>
            <div class='space-grid'>
              {
                spacing.map(s => [
                  <span class='space-grid__label'>{s}px</span>,
                  <div>
                    <div
                      class='space-grid__bar'
                      style={`width:${Math.max(s, 1)}px`}
                    />
                  </div>
                ])
              }
            </div>
          </section>

          <!-- ============================================================ -->
          <!-- ACTIONS -->
          <!-- ============================================================ -->
          <div class='section-group'>
            <header class='section-group__header'>
              <p class='section-group__header-eyebrow'>Group A</p>
              <h2 class='section-group__header-title'>Actions</h2>
            </header>

            <Showcase
              id='button'
              slug='Button'
              title='Button'
              description='The workhorse. 3px square border, inverted fill on primary, no shadow.'
            >
              <Fragment slot='preview'>
                <button class='btn btn--cta'>Start curriculum</button>
                <button class='btn'>Secondary</button>
                <button class='btn btn--danger'>Dangerous</button>
                <button class='btn btn--ghost'>Ghost</button>
                <button class='btn btn--sm'>Small</button>
                <button class='btn btn--lg'>Large</button>
                <button class='btn' disabled>Disabled</button>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Button } from './ui/Button';

export function Actions() {
  return (
    <div style={{ display: 'flex', gap: 12 }}>
      <Button variant="cta">Start curriculum</Button>
      <Button variant="secondary">Secondary</Button>
      <Button variant="danger">Dangerous</Button>
      <Button variant="ghost">Ghost</Button>
    </div>
  );
}`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<button class="btn btn--cta">Start curriculum</button>
<button class="btn">Secondary</button>
<button class="btn btn--danger">Dangerous</button>
<button class="btn btn--ghost">Ghost</button>`}
              />
            </Showcase>

            <Showcase
              id='toggle-button'
              slug='ToggleButton'
              title='Toggle button'
              description='For stateful binary choices — hours pressed, unit selected, dark mode on.'
            >
              <Fragment slot='preview'>
                <button
                  class='toggle-btn'
                  aria-pressed='false'
                  data-toggle-pressed
                  data-label-on='Pressed'
                  data-label-off='Not pressed'>Not pressed</button
                >
                <button
                  class='toggle-btn'
                  aria-pressed='true'
                  data-toggle-pressed
                  data-label-on='Keyboard on'
                  data-label-off='Keyboard off'>Keyboard on</button
                >
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { useState } from 'react';
import { ToggleButton } from './ui/ToggleButton';

export function Pressed() {
  const [on, setOn] = useState(false);
  return <ToggleButton pressed={on} onPressedChange={setOn}>{on ? 'On' : 'Off'}</ToggleButton>;
}`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<button class="toggle-btn" aria-pressed="false">Off</button>
<button class="toggle-btn" aria-pressed="true">On</button>`}
              />
            </Showcase>

            <Showcase
              id='close-button'
              slug='CloseButton'
              title='Close button'
              description='Inline dismiss affordance — modals, alerts, drawers.'
            >
              <Fragment slot='preview'>
                <button class='close-btn' aria-label='Dismiss'>×</button>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { CloseButton } from './ui/CloseButton';

<CloseButton onClick={onDismiss} aria-label="Dismiss" />`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<button class="close-btn" aria-label="Dismiss">×</button>`}
              />
            </Showcase>

            <Showcase
              id='link'
              slug='Link'
              title='Link'
              description='Inline links carry the highlight accent and thicken on hover.'
            >
              <Fragment slot='preview'>
                <p
                  style='margin:0;font-size:18px;color:var(--foreground-secondary)'
                >
                  Explore the <a class='fcc-link' href='#tokens'>token layer</a> to
                  recolor every component at once.
                </p>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Link } from './ui/Link';

<p>Explore the <Link href="#tokens">token layer</Link> to recolor every component.</p>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<a class="fcc-link" href="#tokens">token layer</a>`}
              />
            </Showcase>
          </div>

          <!-- ============================================================ -->
          <!-- FORMS -->
          <!-- ============================================================ -->
          <div class='section-group'>
            <header class='section-group__header'>
              <p class='section-group__header-eyebrow'>Group B</p>
              <h2 class='section-group__header-title'>Forms</h2>
            </header>

            <Showcase
              id='input'
              slug='Input'
              title='Input'
              previewStacked
              description='Text input with a built-in label, helper text, and error slot.'
            >
              <Fragment slot='preview'>
                <div class='form-group' style='max-width:360px;margin:0 auto;'>
                  <label class='form-label' for='email-demo'
                    >Email address</label
                  >
                  <input
                    class='input'
                    id='email-demo'
                    type='email'
                    placeholder='camper@example.com'
                  />
                  <p class='form-help'>
                    We send one curriculum update per week.
                  </p>
                </div>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { FormGroup, Input, HelpBlock } from './ui';

<FormGroup>
  <label htmlFor="email">Email address</label>
  <Input id="email" type="email" placeholder="camper@example.com" />
  <HelpBlock>We send one curriculum update per week.</HelpBlock>
</FormGroup>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<div class="form-group">
  <label class="form-label" for="email">Email address</label>
  <input class="input" id="email" type="email" placeholder="camper@example.com" />
  <p class="form-help">We send one curriculum update per week.</p>
</div>`}
              />
            </Showcase>

            <Showcase
              id='checkbox'
              slug='Checkbox'
              title='Checkbox'
              description='Flat, square, accent-filled checkmark.'
            >
              <Fragment slot='preview'>
                <label class='check'
                  ><input type='checkbox' checked /> I accept the honor code</label
                >
                <label class='check'
                  ><input type='checkbox' /> Email me certificate alerts</label
                >
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Checkbox } from './ui/Checkbox';

<Checkbox defaultChecked label="I accept the honor code" />
<Checkbox label="Email me certificate alerts" />`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<label class="check"><input type="checkbox" checked /> I accept the honor code</label>
<label class="check"><input type="checkbox" /> Email me certificate alerts</label>`}
              />
            </Showcase>

            <Showcase
              id='switch'
              slug='Switch'
              title='Switch'
              description='For settings that take effect immediately — theme, audio, keybinds.'
            >
              <Fragment slot='preview'>
                <label class='switch'
                  ><input type='checkbox' checked /><span class='switch__track'
                    ><span class='switch__thumb'></span></span
                  ><span class='switch__label'>Keyboard shortcuts</span></label
                >
                <label class='switch'
                  ><input type='checkbox' /><span class='switch__track'
                    ><span class='switch__thumb'></span></span
                  ><span class='switch__label'>Sound effects</span></label
                >
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Switch } from './ui/Switch';

<Switch defaultChecked label="Keyboard shortcuts" />
<Switch label="Sound effects" />`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<label class="switch">
  <input type="checkbox" checked />
  <span class="switch__track"><span class="switch__thumb"></span></span>
  <span class="switch__label">Keyboard shortcuts</span>
</label>`}
              />
            </Showcase>

            <Showcase
              id='form-group'
              slug='FormGroup'
              title='Form group'
              previewStacked
              description='Groups a label, control, and help text with consistent spacing.'
            >
              <Fragment slot='preview'>
                <div class='form-group' style='max-width:420px;margin:0 auto;'>
                  <label class='form-label' for='username-demo'>Username</label>
                  <input class='input' id='username-demo' value='camper-42' />
                  <p class='form-help'>Letters, numbers, and dashes. Public.</p>
                </div>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`<FormGroup>
  <label htmlFor="username">Username</label>
  <Input id="username" defaultValue="camper-42" />
  <HelpBlock>Letters, numbers, and dashes. Public.</HelpBlock>
</FormGroup>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<div class="form-group">
  <label class="form-label" for="username">Username</label>
  <input class="input" id="username" value="camper-42" />
  <p class="form-help">Letters, numbers, and dashes. Public.</p>
</div>`}
              />
            </Showcase>

            <Showcase
              id='form-control'
              slug='FormControl'
              title='Form control'
              previewStacked
              description='Low-level text control — no label wrapper, for custom layouts.'
            >
              <Fragment slot='preview'>
                <input
                  class='input'
                  placeholder='Search the curriculum'
                  style='max-width:420px'
                />
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { FormControl } from './ui/FormControl';

<FormControl placeholder="Search the curriculum" />`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<input class="input" placeholder="Search the curriculum" />`}
              />
            </Showcase>
          </div>

          <!-- ============================================================ -->
          <!-- FEEDBACK -->
          <!-- ============================================================ -->
          <div class='section-group'>
            <header class='section-group__header'>
              <p class='section-group__header-eyebrow'>Group C</p>
              <h2 class='section-group__header-title'>Feedback</h2>
            </header>

            <Showcase
              id='alert'
              slug='Alert'
              title='Alert'
              previewStacked
              description='Full-width status surface for page-level state — saved, failed, queued.'
            >
              <Fragment slot='preview'>
                <div class='alert alert--info'>
                  All 28 tests pass. Next challenge unlocked.
                </div>
                <div class='alert alert--warning'>
                  You have one unsaved edit.
                </div>
                <div class='alert alert--danger'>
                  Sign-in failed — check your email address.
                </div>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Alert } from './ui/Alert';

<Alert variant="success">All 28 tests pass. Next challenge unlocked.</Alert>
<Alert variant="warning">You have one unsaved edit.</Alert>
<Alert variant="danger">Sign-in failed — check your email address.</Alert>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<div class="alert alert--info">All 28 tests pass.</div>
<div class="alert alert--warning">You have one unsaved edit.</div>
<div class="alert alert--danger">Sign-in failed — check your email address.</div>`}
              />
            </Showcase>

            <Showcase
              id='callout'
              slug='Callout'
              title='Callout'
              previewStacked
              description='Inline sidebar for curriculum notes, tips, and cautions.'
            >
              <Fragment slot='preview'>
                <aside class='callout callout--tip'>
                  <p class='callout__label'>Tip</p>
                  <p class='callout__body'>
                    You can open the code editor fullscreen with <kbd
                      class='kbd'>F11</kbd
                    >.
                  </p>
                </aside>
                <aside class='callout callout--warning'>
                  <p class='callout__label'>Warning</p>
                  <p class='callout__body'>
                    Running this reset removes local progress for the active
                    challenge.
                  </p>
                </aside>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Callout } from './ui/Callout';

<Callout variant="tip" label="Tip">
  Open the editor fullscreen with <kbd>F11</kbd>.
</Callout>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<aside class="callout callout--tip">
  <p class="callout__label">Tip</p>
  <p class="callout__body">Open the editor fullscreen with <kbd>F11</kbd>.</p>
</aside>`}
              />
            </Showcase>

            <Showcase
              id='badge'
              slug='Badge'
              title='Badge'
              description='Inline status chip — sparingly. Max 2 per row.'
            >
              <Fragment slot='preview'>
                <span class='badge'>Default</span>
                <span class='badge badge--success'>Passed</span>
                <span class='badge badge--warning'>In review</span>
                <span class='badge badge--danger'>Failed</span>
                <span class='badge badge--info'>Preview</span>
                <span class='badge badge--purple'>New</span>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Badge } from './ui/Badge';

<Badge>Default</Badge>
<Badge variant="success">Passed</Badge>
<Badge variant="warning">In review</Badge>
<Badge variant="danger">Failed</Badge>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<span class="badge badge--success">Passed</span>
<span class="badge badge--warning">In review</span>
<span class="badge badge--danger">Failed</span>`}
              />
            </Showcase>

            <Showcase
              id='tooltip'
              slug='Tooltip'
              title='Tooltip'
              description='Contextual hint on hover or focus — keep to 80 chars.'
            >
              <Fragment slot='preview'>
                <span class='tip' tabindex='0'>
                  <button class='btn'>Run tests</button>
                  <span class='tip__bubble' role='tooltip'
                    >Runs the public test suite against your code.</span
                  >
                </span>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Tooltip } from './ui/Tooltip';

<Tooltip content="Runs the public test suite against your code.">
  <Button>Run tests</Button>
</Tooltip>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<span class="tip" data-tip="Runs the public test suite against your code.">
  <button class="btn">Run tests</button>
</span>`}
              />
            </Showcase>

            <Showcase
              id='modal'
              slug='Modal'
              title='Modal'
              previewStacked
              previewPlain
              description='Blocking dialog — confirmations and short-form destructive choices.'
            >
              <Fragment slot='preview'>
                <button class='btn btn--danger' data-modal-trigger='modal-reset'
                  >Open modal</button
                >
                <div
                  class='modal'
                  id='modal-reset'
                  data-open='false'
                  role='dialog'
                  aria-labelledby='modal-reset-title'
                  aria-modal='true'
                >
                  <div class='modal__panel'>
                    <header class='modal__header'>
                      <p class='modal__title' id='modal-reset-title'>
                        Reset progress?
                      </p>
                      <button
                        class='close-btn'
                        data-modal-close
                        aria-label='Close'>×</button
                      >
                    </header>
                    <div class='modal__body'>
                      <p style='margin:0'>
                        You completed 17 of 32 steps in <strong
                          >Responsive Web Design</strong
                        >. Resetting removes your local code for every one.
                      </p>
                    </div>
                    <footer class='modal__footer'>
                      <button class='btn' data-modal-close>Cancel</button>
                      <button class='btn btn--danger' data-modal-close
                        >Reset progress</button
                      >
                    </footer>
                  </div>
                </div>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
                code={`import { Modal } from './ui/Modal';

<Modal open={open} onClose={close} title="Reset progress?">
  <Modal.Body>
    You completed 17 of 32 steps in Responsive Web Design.
  </Modal.Body>
  <Modal.Footer>
    <Button onClick={close}>Cancel</Button>
    <Button variant="danger" onClick={reset}>Reset progress</Button>
  </Modal.Footer>
</Modal>`}
              />
              <Code
                slot='vanilla'
                lang='html'
                code={`<div class="modal" role="dialog" aria-labelledby="m-title">
  <header class="modal__header">
    <p class="modal__title" id="m-title">Reset progress?</p>
    <button class="close-btn" aria-label="Close">×</button>
  </header>
  <div class="modal__body"><p>...</p></div>
  <footer class="modal__footer">
    <button class="btn">Cancel</button>
    <button class="btn btn--danger">Reset progress</button>
  </footer>
</div>`}
              />
            </Showcase>
          </div>

          <!-- ============================================================ -->
          <!-- LAYOUT -->
          <!-- ============================================================ -->
          <div class='section-group'>
            <header class='section-group__header'>
              <p class='section-group__header-eyebrow'>Group D</p>
              <h2 class='section-group__header-title'>Layout</h2>
            </header>

            <Showcase
              id='card'
              slug='Card'
              title='Card'
              previewStacked
              description='Flat bordered container. Grid-friendly. No shadow, no hover lift.'
            >
              <Fragment slot='preview'>
                <article class='card' style='max-width:480px;margin:0 auto;'>
                  <header class='card__header'>
                    <span class='card__dot card__dot--purple' aria-hidden='true'
                    ></span>
                    <p class='card__hours'>300 HOURS</p>
                  </header>
                  <h3 class='card__title'>Responsive Web Design</h3>
                  <p class='card__body'>
                    Build five certification projects using HTML, CSS, flexbox,
                    grid, and accessibility primitives.
                  </p>
                  <div class='progress'>
                    <div
                      class='progress__bar progress__bar--purple'
                      style='width:62%'
                    >
                    </div>
                  </div>
                  <footer class='card__footer'>
                    <span>62% complete</span>
                    <a class='fcc-link' href='#'>Resume →</a>
                  </footer>
                </article>
              </Fragment>
              <Code
                slot='react'
                lang='tsx'
