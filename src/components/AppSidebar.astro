---
import { nav } from '../data/nav.ts';
---
<aside class="sidebar" aria-label="Component navigation">
  <div class="sidebar__intro">
    <p class="sidebar__intro-kicker">fCC UIKit</p>
    <p class="sidebar__intro-title">Component storybook</p>
  </div>

  {nav.map((section) => (
    <nav class="sidebar__section" aria-label={section.label}>
      <p class="sidebar__section-title">{section.label}</p>
      <ul class="sidebar__list">
        {section.items.map((item) => (
          <li>
            <a
              class="sidebar__link"
              href={`#${item.id}`}
              data-sidebar-link
              data-target={item.id}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  ))}

  <p class="sidebar__hint">Press <kbd class="kbd">/</kbd> to search</p>
</aside>

<script is:inline>
  (function () {
    const links = Array.from(document.querySelectorAll('[data-sidebar-link]'));
    if (!links.length) return;
    const byId = new Map(links.map((a) => [a.getAttribute('data-target'), a]));

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const id = entry.target.getAttribute('id');
        if (!id) return;
        links.forEach((a) => a.classList.remove('is-active'));
        const match = byId.get(id);
        if (match) match.classList.add('is-active');
      });
    }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });

    document.querySelectorAll('section[id]').forEach((s) => observer.observe(s));
  })();
</script>
